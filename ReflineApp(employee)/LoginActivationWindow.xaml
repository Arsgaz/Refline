<Window x:Class="Refline.LoginActivationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Refline — вход и активация"
        Height="620"
        Width="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Border Width="420"
                Padding="32"
                Background="#111827"
                BorderBrush="#2DC7FF"
                BorderThickness="1"
                CornerRadius="16"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,24">
                    <materialDesign:PackIcon Kind="ShieldKeyOutline"
                                             Width="52"
                                             Height="52"
                                             Foreground="#2DC7FF"
                                             HorizontalAlignment="Center"/>
                    <TextBlock Text="Refline Employee"
                               Margin="0,16,0,6"
                               Foreground="#F9FAFB"
                               FontSize="24"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Войдите и активируйте устройство"
                               Foreground="#9CA3AF"
                               FontSize="13"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,14"
                         Height="52"
                         Foreground="#F9FAFB"
                         Background="#0D1117"
                         BorderBrush="#374151"
                         materialDesign:HintAssist.Hint="Login"
                         materialDesign:TextFieldAssist.DecorationVisibility="Visible"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                <PasswordBox x:Name="PasswordInput"
                             PasswordChanged="PasswordInput_PasswordChanged"
                             Margin="0,0,0,14"
                             Height="52"
                             Foreground="#F9FAFB"
                             Background="#0D1117"
                             BorderBrush="#374151"
                             materialDesign:HintAssist.Hint="Password"
                             materialDesign:TextFieldAssist.DecorationVisibility="Visible"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"/>

                <TextBox Text="{Binding LicenseKey, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,18"
                         Height="52"
                         Foreground="#F9FAFB"
                         Background="#0D1117"
                         BorderBrush="#374151"
                         materialDesign:HintAssist.Hint="License Key"
                         materialDesign:TextFieldAssist.DecorationVisibility="Visible"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                <Button Command="{Binding LoginAndActivateCommand}"
                        Height="48"
                        Style="{StaticResource AnimatedButton}"
                        BorderBrush="#2DC7FF"
                        Foreground="#DDE6F1"
                        Background="Transparent"
                        Cursor="Hand">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="LoginVariant"
                                                 Width="20"
                                                 Height="20"
                                                 Margin="0,0,8,0"
                                                 Foreground="#DDE6F1"/>
                        <TextBlock Text="Войти и активировать"
                                   FontWeight="SemiBold"
                                   FontSize="14"/>
                    </StackPanel>
                </Button>

                <ProgressBar Margin="0,16,0,0"
                             Height="4"
                             IsIndeterminate="True"
                             Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <TextBlock Text="{Binding ErrorMessage}"
                           Margin="0,16,0,0"
                           Foreground="#F87171"
                           FontSize="13"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
