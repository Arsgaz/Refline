<Page x:Class="Refline.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="#0D1117">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40">

            <!-- ===== Заголовки ===== -->
            <TextBlock Text="Трекер времени"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="#2DC7FF"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Запускайте трекинг, чтобы фиксировать рабочую активность и получать отчёты."
                       FontSize="16"
                       Foreground="#9BAEC2"
                       Margin="0,0,0,30"
                       TextWrapping="Wrap" />

            <!-- ===== Центральный блок с таймером ===== -->
            <Border Background="#111827"
                    CornerRadius="14"
                    Padding="30"
                    HorizontalAlignment="Center"
                    Width="680"
                    Margin="0,0,0,40">

                <StackPanel HorizontalAlignment="Center">

                    <!-- Статус -->
                    <TextBlock x:Name="StatusText"
                               Text="{Binding StatusText}"
                               Foreground="#FF6B6B"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"
                               HorizontalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTracking}" Value="True">
                                        <Setter Property="Foreground" Value="#00FFC8" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Таймер -->
                    <TextBlock x:Name="TimerText"
                               Text="{Binding SessionTimeString}"
                               FontSize="56"
                               FontWeight="Bold"
                               Foreground="#2DC7FF"
                               Margin="0,0,0,20"
                               HorizontalAlignment="Center"/>

                    <!-- Кнопки -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">

                        <Button x:Name="ToggleTrackingButton"
                                Content="{Binding StartStopButtonContent}"
                                Command="{Binding ToggleTrackingCommand}"
                                Width="180"
                                Height="50"
                                FontSize="18"
                                Style="{DynamicResource MaterialDesignOutlinedButton}">
                            <Button.Foreground>
                                <SolidColorBrush Color="#2DC7FF"/>
                            </Button.Foreground>
                            <Button.BorderBrush>
                                <SolidColorBrush Color="#2DC7FF"/>
                            </Button.BorderBrush>
                        </Button>

                    </StackPanel>

                </StackPanel>

            </Border>


            <!-- ===== НИЖНИЕ МЕТРИКИ ===== -->
            <UniformGrid Columns="3" Margin="0,0,0,0" HorizontalAlignment="Center">
                <Border Background="#111827"
                        CornerRadius="12"
                        Padding="20"
                        Width="260"
                        Margin="0,0,20,20">
                    <StackPanel>
                        <TextBlock Text="Общее время"
                                   Foreground="#9BAEC2"
                                   FontSize="15"/>
                        <TextBlock Text="{Binding TotalTrackedTimeText}"
                                   Foreground="#2DC7FF"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="#111827"
                        CornerRadius="12"
                        Padding="20"
                        Width="260"
                        Margin="0,0,20,20">
                    <StackPanel>
                        <TextBlock Text="Активное время"
                                   Foreground="#9BAEC2"
                                   FontSize="15"/>
                        <TextBlock Text="{Binding ActiveTimeText}"
                                   Foreground="#2DC7FF"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="#111827"
                        CornerRadius="12"
                        Padding="20"
                        Width="260"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Время бездействия"
                                   Foreground="#9BAEC2"
                                   FontSize="15"/>
                        <TextBlock Text="{Binding IdleTimeText}"
                                   Foreground="#2DC7FF"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="#111827"
                        CornerRadius="12"
                        Padding="20"
                        Width="260"
                        Margin="0,0,20,0">
                    <StackPanel>
                        <TextBlock Text="Продуктивное время"
                                   Foreground="#9BAEC2"
                                   FontSize="15"/>
                        <TextBlock Text="{Binding ProductiveTimeText}"
                                   Foreground="#2DC7FF"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="#111827"
                        CornerRadius="12"
                        Padding="20"
                        Width="260"
                        Margin="0,0,20,0">
                    <StackPanel>
                        <TextBlock Text="Топ приложение"
                                   Foreground="#9BAEC2"
                                   FontSize="15"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding TopApplicationText}"
                                   Foreground="#2DC7FF"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Margin="0,5,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>

                <Border Background="#111827"
                        CornerRadius="12"
                        Padding="20"
                        Width="260">
                    <StackPanel>
                        <TextBlock Text="Ведущая категория"
                                   Foreground="#9BAEC2"
                                   FontSize="15"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding TopCategoryText}"
                                   Foreground="#2DC7FF"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Margin="0,5,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Background="#111827"
                    CornerRadius="12"
                    Padding="20"
                    Margin="0,28,0,0">
                <StackPanel>
                    <TextBlock Text="Диагностика текущей классификации"
                               Foreground="#2DC7FF"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Приложение" Foreground="#9BAEC2" Margin="0,0,0,10" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentTrackedAppText}" Foreground="#DDE6F1" Margin="0,0,0,10" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Окно" Foreground="#9BAEC2" Margin="0,0,0,10" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CurrentTrackedWindowText}" Foreground="#DDE6F1" Margin="0,0,0,10" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Категория" Foreground="#9BAEC2" Margin="0,0,0,10" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CurrentTrackedCategoryText}" Foreground="#2DC7FF" Margin="0,0,0,10" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Источник" Foreground="#9BAEC2" Margin="0,0,0,10" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CurrentClassificationSourceText}" Foreground="#DDE6F1" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Совпавшее правило" Foreground="#9BAEC2" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding CurrentMatchedRuleText}" Foreground="#DDE6F1" TextWrapping="Wrap" />
                    </Grid>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
