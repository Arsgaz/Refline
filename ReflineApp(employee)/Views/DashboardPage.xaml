<Page x:Class="Refline.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="#0B1220">

    <Page.Resources>
        <SolidColorBrush x:Key="PageBaseBrush" Color="#0B1220"/>
        <SolidColorBrush x:Key="PageSecondaryBrush" Color="#10192B"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#111827"/>
        <SolidColorBrush x:Key="PanelHoverBrush" Color="#162033"/>
        <SolidColorBrush x:Key="PanelActiveBrush" Color="#11263A"/>
        <SolidColorBrush x:Key="BorderBrushNeutral" Color="#1E2A3D"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#DDE6F1"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#94A3B8"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2DC7FF"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#63D8FF"/>

        <LinearGradientBrush x:Key="PageBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0B1220" Offset="0"/>
            <GradientStop Color="#10192B" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushNeutral}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="MetricLabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="MetricValueTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="ReflineActionButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushNeutral}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PanelHoverBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PanelActiveBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryTrackingButtonStyle" TargetType="Button" BasedOn="{StaticResource ReflineActionButton}">
            <Setter Property="MinWidth" Value="220"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Background" Value="{StaticResource PanelActiveBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,28">
                    <TextBlock Text="Трекер времени"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="Запускайте трекинг, чтобы фиксировать рабочую активность и получать отчёты."
                               FontSize="15"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Border Grid.Row="1"
                        Style="{StaticResource PanelBorderStyle}"
                        Padding="28"
                        Margin="0,0,0,28"
                        MaxWidth="920"
                        HorizontalAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource PanelActiveBrush}"
                                BorderBrush="{StaticResource BorderBrushNeutral}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="14,8"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,18">
                            <TextBlock x:Name="StatusText"
                                       Text="{Binding StatusText}"
                                       Foreground="{StaticResource AppErrorBrush}"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       MinWidth="260"
                                       MaxWidth="640">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTracking}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AppSuccessBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <TextBlock Grid.Row="1"
                                   x:Name="TimerText"
                                   Text="{Binding SessionTimeString}"
                                   FontSize="60"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,0,0,20"/>

                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <Button x:Name="ToggleTrackingButton"
                                    Content="{Binding StartStopButtonContent}"
                                    Command="{Binding ToggleTrackingCommand}"
                                    Style="{StaticResource PrimaryTrackingButtonStyle}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="Ключевые показатели"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,14"/>

                    <UniformGrid Columns="3">
                        <Border Style="{StaticResource PanelBorderStyle}"
                                Height="124"
                                Margin="0,0,16,16">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Общее время" Style="{StaticResource MetricLabelTextStyle}"/>
                                <TextBlock Text="{Binding TotalTrackedTimeText}"
                                           Style="{StaticResource MetricValueTextStyle}"
                                           Foreground="{StaticResource AccentBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelBorderStyle}"
                                Height="124"
                                Margin="0,0,16,16">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Активное время" Style="{StaticResource MetricLabelTextStyle}"/>
                                <TextBlock Text="{Binding ActiveTimeText}"
                                           Style="{StaticResource MetricValueTextStyle}"
                                           Foreground="{StaticResource AccentBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelBorderStyle}"
                                Height="124"
                                Margin="0,0,0,16">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Время бездействия" Style="{StaticResource MetricLabelTextStyle}"/>
                                <TextBlock Text="{Binding IdleTimeText}"
                                           Style="{StaticResource MetricValueTextStyle}"
                                           Foreground="{StaticResource AccentBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelBorderStyle}"
                                Height="124"
                                Margin="0,0,16,0">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Продуктивное время"
                                           Style="{StaticResource MetricLabelTextStyle}"/>
                                <TextBlock Text="{Binding ProductiveTimeText}"
                                           Style="{StaticResource MetricValueTextStyle}"
                                           Foreground="{StaticResource AccentBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelBorderStyle}"
                                Height="124"
                                Margin="0,0,16,0">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Топ приложение"
                                           Style="{StaticResource MetricLabelTextStyle}"/>
                                <TextBlock Text="{Binding TopApplicationText}"
                                           Style="{StaticResource MetricValueTextStyle}"
                                           FontSize="24"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelBorderStyle}"
                                Height="124"
                                Margin="0">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Ведущая категория"
                                           Style="{StaticResource MetricLabelTextStyle}"/>
                                <TextBlock Text="{Binding TopCategoryText}"
                                           Style="{StaticResource MetricValueTextStyle}"
                                           FontSize="24"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
