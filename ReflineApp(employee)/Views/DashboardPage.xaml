<Page x:Class="Refline.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40">

            <!-- ===== Заголовки ===== -->
            <TextBlock Text="Трекер времени"
                       FontSize="32"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource AppAccentBrush}"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Запускайте трекинг, чтобы фиксировать рабочую активность и получать отчёты."
                       FontSize="16"
                       Foreground="{StaticResource AppMutedTextBrush}"
                       Margin="0,0,0,30"
                       TextWrapping="Wrap" />

            <!-- ===== Центральный блок с таймером ===== -->
            <Border Style="{StaticResource CardBorderStyle}"
                    HorizontalAlignment="Center"
                    Width="680"
                    Margin="0,0,0,40"
                    Padding="30">

                <StackPanel HorizontalAlignment="Center">

                    <!-- Статус -->
                    <TextBlock x:Name="StatusText"
                               Text="{Binding StatusText}"
                               Foreground="{StaticResource AppErrorBrush}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"
                               HorizontalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTracking}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource AppSuccessBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Таймер -->
                    <TextBlock x:Name="TimerText"
                               Text="{Binding SessionTimeString}"
                               FontSize="56"
                               FontWeight="Bold"
                               Foreground="{StaticResource AppAccentBrush}"
                               Margin="0,0,0,20"
                               HorizontalAlignment="Center"/>

                    <!-- Кнопки -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="ToggleTrackingButton"
                                Content="{Binding StartStopButtonContent}"
                                Command="{Binding ToggleTrackingCommand}"
                                Width="180"
                                Height="50"
                                FontSize="18" />
                    </StackPanel>

                </StackPanel>

            </Border>

            <!-- ===== НИЖНИЕ МЕТРИКИ ===== -->
            <UniformGrid Columns="3" HorizontalAlignment="Center">

                <Border Style="{StaticResource CardBorderStyle}" Width="260" Margin="0,0,20,20">
                    <StackPanel>
                        <TextBlock Text="Общее время" Foreground="{StaticResource AppMutedTextBrush}" FontSize="15"/>
                        <TextBlock Text="{Binding TotalTrackedTimeText}" Foreground="{StaticResource AppAccentBrush}"
                                   FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Width="260" Margin="0,0,20,20">
                    <StackPanel>
                        <TextBlock Text="Активное время" Foreground="{StaticResource AppMutedTextBrush}" FontSize="15"/>
                        <TextBlock Text="{Binding ActiveTimeText}" Foreground="{StaticResource AppAccentBrush}"
                                   FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Width="260" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Время бездействия" Foreground="{StaticResource AppMutedTextBrush}" FontSize="15"/>
                        <TextBlock Text="{Binding IdleTimeText}" Foreground="{StaticResource AppAccentBrush}"
                                   FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Width="260" Margin="0,0,20,0">
                    <StackPanel>
                        <TextBlock Text="Продуктивное время" Foreground="{StaticResource AppMutedTextBrush}"
                                   FontSize="15" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding ProductiveTimeText}" Foreground="{StaticResource AppAccentBrush}"
                                   FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Width="260" Margin="0,0,20,0">
                    <StackPanel>
                        <TextBlock Text="Топ приложение" Foreground="{StaticResource AppMutedTextBrush}"
                                   FontSize="15" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding TopApplicationText}" Foreground="{StaticResource AppAccentBrush}"
                                   FontSize="24" FontWeight="Bold" Margin="0,5,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Width="260">
                    <StackPanel>
                        <TextBlock Text="Ведущая категория" Foreground="{StaticResource AppMutedTextBrush}"
                                   FontSize="15" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding TopCategoryText}" Foreground="{StaticResource AppAccentBrush}"
                                   FontSize="24" FontWeight="Bold" Margin="0,5,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

        </StackPanel>
    </ScrollViewer>
</Page>
