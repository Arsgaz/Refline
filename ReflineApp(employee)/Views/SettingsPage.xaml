<Page x:Class="Refline.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40">

            <!-- ===== Заголовок ===== -->
            <TextBlock Text="Настройки"
                       FontSize="32"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource AppAccentBrush}"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Управляйте параметрами приложения, путями сохранения и корпоративным доступом."
                       FontSize="16"
                       Foreground="{StaticResource AppMutedTextBrush}"
                       Margin="0,0,0,25"
                       TextWrapping="Wrap" />

            <StackPanel Width="620" HorizontalAlignment="Center">

                <!-- ░░ БЛОК: Пути сохранения отчётов ░░ -->
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,25">
                    <StackPanel>
                        <TextBlock Text="Путь сохранения отчётов"
                                   FontSize="20"
                                   Foreground="{StaticResource AppAccentBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Укажите папку, куда будут сохраняться PDF и XLS отчёты."
                                   FontSize="14"
                                   Foreground="{StaticResource AppMutedTextBrush}"
                                   Margin="0,0,0,15"
                                   TextWrapping="Wrap"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="PathBox"
                                     Text="{Binding ReportsPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="420"
                                     Height="44" />

                            <Button Content="📂"
                                    Command="{Binding SelectFolderCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Width="50"
                                    Height="44"
                                    Margin="10,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ░░ БЛОК: Системные параметры ░░ -->
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,25">
                    <StackPanel>
                        <TextBlock Text="Системные параметры"
                                   FontSize="20"
                                   Foreground="{StaticResource AppAccentBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Настройка автозапуска, фонового режима и логирования."
                                   FontSize="14"
                                   Foreground="{StaticResource AppMutedTextBrush}"
                                   Margin="0,0,0,15"
                                   TextWrapping="Wrap"/>

                        <CheckBox Content="Запускать Refline при старте Windows"
                                  IsChecked="{Binding AutoStartWindows, Mode=TwoWay}"
                                  Margin="0,0,0,8"/>

                        <CheckBox Content="Разрешить фоновый сбор активности"
                                  IsChecked="{Binding AllowBackgroundTracking, Mode=TwoWay}"
                                  Margin="0,0,0,8"/>

                        <CheckBox Content="Вести локальный лог работы приложения"
                                  IsChecked="{Binding EnableLocalLog, Mode=TwoWay}"
                                  Margin="0,0,0,8"/>
                    </StackPanel>
                </Border>

                <!-- ░░ Кнопка сохранить ░░ -->
                <Button Content="💾  Сохранить настройки"
                        Command="{Binding SaveSettingsCommand}"
                        Width="260"
                        Height="50"
                        HorizontalAlignment="Center"/>

                <Button Content="Выйти из аккаунта"
                        Command="{Binding LogoutCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="260"
                        Height="50"
                        HorizontalAlignment="Center"
                        Margin="0,16,0,0"/>

            </StackPanel>

        </StackPanel>
    </ScrollViewer>

</Page>
