<Page x:Class="Refline.Views.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="#0B1220">

    <Page.Resources>
        <SolidColorBrush x:Key="PageBaseBrush" Color="#0B1220"/>
        <SolidColorBrush x:Key="PageSecondaryBrush" Color="#10192B"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#111827"/>
        <SolidColorBrush x:Key="PanelHoverBrush" Color="#162033"/>
        <SolidColorBrush x:Key="PanelActiveBrush" Color="#11263A"/>
        <SolidColorBrush x:Key="BorderBrushNeutral" Color="#1E2A3D"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#DDE6F1"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#94A3B8"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2DC7FF"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#63D8FF"/>

        <LinearGradientBrush x:Key="PageBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0B1220" Offset="0"/>
            <GradientStop Color="#10192B" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushNeutral}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="MetricLabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="MetricValueTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="ReflineActionButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushNeutral}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PanelHoverBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PanelActiveBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PeriodToggleButton" TargetType="Button" BasedOn="{StaticResource ReflineActionButton}">
            <Setter Property="MinWidth" Value="112"/>
        </Style>

        <Style x:Key="SelectedDayButton" TargetType="Button" BasedOn="{StaticResource PeriodToggleButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDayPeriodSelected}" Value="True">
                    <Setter Property="Background" Value="{StaticResource PanelActiveBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SelectedWeekButton" TargetType="Button" BasedOn="{StaticResource PeriodToggleButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsWeekPeriodSelected}" Value="True">
                    <Setter Property="Background" Value="{StaticResource PanelActiveBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SelectedMonthButton" TargetType="Button" BasedOn="{StaticResource PeriodToggleButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMonthPeriodSelected}" Value="True">
                    <Setter Property="Background" Value="{StaticResource PanelActiveBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,28">
                    <TextBlock Text="Отчёты и статистика"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Выбирайте день, неделю или месяц, чтобы пересчитать метрики, графики и активность."
                               FontSize="15"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Border Grid.Row="1"
                        Style="{StaticResource PanelBorderStyle}"
                        Margin="0,0,0,28">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,18">
                            <TextBlock Text="Период отчёта"
                                       Style="{StaticResource SectionTitleTextStyle}"
                                       Margin="0,0,0,12"/>
                            <WrapPanel>
                                <Button Content="День"
                                        Command="{Binding SetReportPeriodCommand}"
                                        CommandParameter="Day"
                                        Style="{StaticResource SelectedDayButton}"
                                        Margin="0,0,12,0"/>
                                <Button Content="Неделя"
                                        Command="{Binding SetReportPeriodCommand}"
                                        CommandParameter="Week"
                                        Style="{StaticResource SelectedWeekButton}"
                                        Margin="0,0,12,0"/>
                                <Button Content="Месяц"
                                        Command="{Binding SetReportPeriodCommand}"
                                        CommandParameter="Month"
                                        Style="{StaticResource SelectedMonthButton}"/>
                            </WrapPanel>
                        </StackPanel>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="←"
                                        Width="48"
                                        Height="44"
                                        Command="{Binding PreviousReportPeriodCommand}"
                                        Style="{StaticResource ReflineActionButton}"
                                        Margin="0,0,10,0"/>
                                <Button Content="→"
                                        Width="48"
                                        Height="44"
                                        Command="{Binding NextReportPeriodCommand}"
                                        Style="{StaticResource ReflineActionButton}"
                                        Margin="0,0,10,0"/>
                                <Button Content="{Binding CurrentPeriodButtonText}"
                                        Height="44"
                                        Command="{Binding CurrentReportPeriodCommand}"
                                        Style="{StaticResource ReflineActionButton}"
                                        Padding="18,8"/>
                            </StackPanel>

                            <Border Grid.Column="2"
                                    Background="{StaticResource PanelActiveBrush}"
                                    BorderBrush="{StaticResource BorderBrushNeutral}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="18,14"
                                    VerticalAlignment="Center">
                                <StackPanel>
                                    <TextBlock Text="Выбранный период"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="13"/>
                                    <TextBlock Text="{Binding SelectedPeriodLabel}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="24"
                                               FontWeight="SemiBold"
                                               Margin="0,6,0,0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Button Grid.Column="4"
                                    Content="Экспорт в TXT"
                                    Command="{Binding ExportCommand}"
                                    Style="{StaticResource ReflineActionButton}"
                                    Height="44"
                                    Padding="18,8"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource AccentBrush}"/>
                        </Grid>
                    </Grid>
                </Border>

                <WrapPanel Grid.Row="2" Margin="0,0,0,28">
                    <Border Style="{StaticResource PanelBorderStyle}"
                            Width="250"
                            Height="124"
                            Margin="0,0,16,16">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Общее время" Style="{StaticResource MetricLabelTextStyle}"/>
                            <TextBlock Text="{Binding ReportTotalTrackedTimeText}"
                                       Style="{StaticResource MetricValueTextStyle}"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelBorderStyle}"
                            Width="250"
                            Height="124"
                            Margin="0,0,16,16">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Активное время" Style="{StaticResource MetricLabelTextStyle}"/>
                            <TextBlock Text="{Binding ReportActiveTimeText}"
                                       Style="{StaticResource MetricValueTextStyle}"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelBorderStyle}"
                            Width="250"
                            Height="124"
                            Margin="0,0,16,16">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Время бездействия" Style="{StaticResource MetricLabelTextStyle}"/>
                            <TextBlock Text="{Binding ReportIdleTimeText}"
                                       Style="{StaticResource MetricValueTextStyle}"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelBorderStyle}"
                            Width="250"
                            Height="124"
                            Margin="0,0,16,16">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Продуктивное время" Style="{StaticResource MetricLabelTextStyle}"/>
                            <TextBlock Text="{Binding ReportProductiveTimeText}"
                                       Style="{StaticResource MetricValueTextStyle}"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelBorderStyle}"
                            Width="250"
                            Height="124"
                            Margin="0,0,16,16">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Топ приложение" Style="{StaticResource MetricLabelTextStyle}"/>
                            <TextBlock Text="{Binding ReportTopApplicationText}"
                                       Style="{StaticResource MetricValueTextStyle}"
                                       FontSize="24"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelBorderStyle}"
                            Width="250"
                            Height="124"
                            Margin="0,0,16,16">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Ведущая категория" Style="{StaticResource MetricLabelTextStyle}"/>
                            <TextBlock Text="{Binding ReportTopCategoryText}"
                                       Style="{StaticResource MetricValueTextStyle}"
                                       FontSize="24"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <Grid Grid.Row="3" Margin="0,0,0,28">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0"
                            Grid.Column="0"
                            Style="{StaticResource PanelBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Распределение времени по категориям"
                                       Style="{StaticResource SectionTitleTextStyle}"/>
                            <Grid Height="320">
                                <lvc:PieChart Series="{Binding CategoryTimeSeries}"
                                              LegendPosition="Right"
                                              LegendTextPaint="{Binding LegendTextPaint}"
                                              Background="Transparent" />

                                <TextBlock Text="{Binding CategoryChartPlaceholderText}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="16"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasCategoryChartData}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0"
                            Grid.Column="2"
                            Style="{StaticResource PanelBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Топ приложений по времени"
                                       Style="{StaticResource SectionTitleTextStyle}"/>
                            <lvc:CartesianChart Series="{Binding TopApplicationsSeries}"
                                                XAxes="{Binding TopApplicationsXAxes}"
                                                YAxes="{Binding TopApplicationsYAxes}"
                                                Height="320"
                                                LegendPosition="Hidden"
                                                Background="Transparent"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="DailyTrendBorder"
                            Grid.Row="1"
                            Grid.ColumnSpan="3"
                            Style="{StaticResource PanelBorderStyle}"
                            Margin="0,20,0,0">
                        <StackPanel>
                            <TextBlock Text="Динамика по дням"
                                       Style="{StaticResource SectionTitleTextStyle}"/>
                            <Grid Height="320">
                                <lvc:CartesianChart x:Name="DailyTrendChart"
                                                    Series="{Binding DailyTrendSeries}"
                                                    XAxes="{Binding DailyTrendXAxes}"
                                                    YAxes="{Binding DailyTrendYAxes}"
                                                    LegendPosition="Top"
                                                    LegendTextPaint="{Binding LegendTextPaint}"
                                                    Background="Transparent" />

                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="16"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Setter Property="Text" Value="График по дням доступен для недели и месяца"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowDailyTrendChart}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding HasDailyTrendChartData}" Value="False">
                                                    <Setter Property="Text" Value="{Binding DailyTrendChartPlaceholderText}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <StackPanel Grid.Row="4">
                    <TextBlock Text="Активности за период"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,14"/>

                    <Border Style="{StaticResource PanelBorderStyle}" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="{StaticResource PanelActiveBrush}"
                                    BorderBrush="{StaticResource BorderBrushNeutral}"
                                    BorderThickness="0,0,0,1"
                                    CornerRadius="12,12,0,0"
                                    Padding="18,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*"/>
                                        <ColumnDefinition Width="1.6*"/>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Приложение" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" FontWeight="SemiBold" Grid.Column="0"/>
                                    <TextBlock Text="Окно" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" FontWeight="SemiBold" Grid.Column="1" Margin="12,0,12,0"/>
                                    <TextBlock Text="Категория" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" FontWeight="SemiBold" Grid.Column="2" Margin="12,0,12,0"/>
                                    <TextBlock Text="Источник" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" FontWeight="SemiBold" Grid.Column="3" Margin="12,0,12,0"/>
                                    <TextBlock Text="Совпавшее правило" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" FontWeight="SemiBold" Grid.Column="4" Margin="12,0,12,0"/>
                                    <TextBlock Text="Время" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" FontWeight="SemiBold" Grid.Column="5"/>
                                </Grid>
                            </Border>

                            <ItemsControl Grid.Row="1" ItemsSource="{Binding ReportActivities}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource BorderBrushNeutral}"
                                                BorderThickness="0,0,0,1"
                                                Padding="18,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1.2*"/>
                                                    <ColumnDefinition Width="1.6*"/>
                                                    <ColumnDefinition Width="180"/>
                                                    <ColumnDefinition Width="180"/>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="120"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding AppName}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Grid.Column="0"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding WindowTitle}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Grid.Column="1"
                                                           Margin="12,0,12,0"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding CategoryDisplay}"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           Grid.Column="2"
                                                           Margin="12,0,12,0"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding CategorySourceDisplay}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Grid.Column="3"
                                                           Margin="12,0,12,0"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding MatchedRuleDisplay}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Grid.Column="4"
                                                           Margin="12,0,12,0"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding DurationString}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Grid.Column="5"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
