<Page x:Class="Refline.Views.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="#0D1117">

	<Page.Resources>

		<!-- 🔵 Стиль кнопки Refline -->
		<Style x:Key="ReflineActionButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
			<Setter Property="Foreground" Value="#2DC7FF"/>
			<Setter Property="FontSize" Value="17"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Padding" Value="12 6"/>
			<Setter Property="Margin" Value="0 0 0 10"/>
			<Setter Property="BorderBrush" Value="#2DC7FF"/>
			<Setter Property="BorderThickness" Value="1.4"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Background" Value="#0D1117"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="border"
                                CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>

						<ControlTemplate.Triggers>
							<!-- Hover -->
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="border" Property="BorderBrush" Value="#4DE0FF"/>
								<Setter Property="Foreground" Value="#4DE0FF"/>
							</Trigger>

							<!-- Pressed -->
							<Trigger Property="IsPressed" Value="True">
								<Setter TargetName="border" Property="BorderBrush" Value="#1FA1CD"/>
								<Setter Property="Foreground" Value="#1FA1CD"/>
								<Setter TargetName="border" Property="Background" Value="#111827"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- 🔵 Анимация появления -->
		<Style x:Key="AppearScale" TargetType="FrameworkElement">
			<Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
			<Setter Property="RenderTransform">
				<Setter.Value>
					<ScaleTransform ScaleX="0.82" ScaleY="0.82"/>
				</Setter.Value>
			</Setter>
		</Style>

	</Page.Resources>


	<ScrollViewer VerticalScrollBarVisibility="Auto">
		<StackPanel Margin="40">

			<!-- Заголовок -->
			<TextBlock Text="Отчёты и статистика"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="#2DC7FF"
                       Margin="0,0,0,16"/>

			
			<!-- Кнопка -->
			<Button x:Name="ShowReportButton"
                    Content="📊 Сформировать отчёт"
                    Width="260" Height="55"
                    Style="{StaticResource ReflineActionButton}"
                    Click="ShowReport_Click"
                    Margin="0,0,0,40"/>


			<!-- ▼▼▼ ОТЧЁТ ▼▼▼ -->
			<Grid x:Name="ReportArea"
                  Visibility="Collapsed"
                  Opacity="0">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>

				<!-- Метрики -->
				<WrapPanel Grid.Row="0" Margin="0,0,0,30">

					<!-- Метрика 1 -->
					<Border x:Name="Card1"
                            Style="{StaticResource AppearScale}"
                            Background="#111827"
                            CornerRadius="12"
                            Padding="20"
                            Width="260"
                            Margin="0,0,20,20">

						<StackPanel>
							<TextBlock Text="Общее время"
                                       Foreground="#9BAEC2"
                                       FontSize="15"/>
							<TextBlock Text="{Binding TotalTrackedTimeText}"
                                       Foreground="#2DC7FF"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Margin="0,5,0,0"/>
						</StackPanel>
					</Border>


					<!-- Метрика 2 -->
					<Border x:Name="Card2"
                            Style="{StaticResource AppearScale}"
                            Background="#111827"
                            CornerRadius="12"
                            Padding="20"
                            Width="260"
                            Margin="0,0,20,20">

						<StackPanel>
							<TextBlock Text="Активное время"
                                       Foreground="#9BAEC2"
                                       FontSize="15"/>
							<TextBlock Text="{Binding ActiveTimeText}"
                                       Foreground="#2DC7FF"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Margin="0,5,0,0"/>
						</StackPanel>
					</Border>

					<Border Style="{StaticResource AppearScale}"
                            Background="#111827"
                            CornerRadius="12"
                            Padding="20"
                            Width="260"
                            Margin="0,0,20,20">

						<StackPanel>
							<TextBlock Text="Время бездействия"
                                       Foreground="#9BAEC2"
                                       FontSize="15"/>
							<TextBlock Text="{Binding IdleTimeText}"
                                       Foreground="#2DC7FF"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Margin="0,5,0,0"/>
						</StackPanel>
					</Border>

					<Border Style="{StaticResource AppearScale}"
                            Background="#111827"
                            CornerRadius="12"
                            Padding="20"
                            Width="260"
                            Margin="0,0,20,20">

						<StackPanel>
							<TextBlock Text="Продуктивное время"
                                       Foreground="#9BAEC2"
                                       FontSize="15"/>
							<TextBlock Text="{Binding ProductiveTimeText}"
                                       Foreground="#2DC7FF"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Margin="0,5,0,0"/>
						</StackPanel>
					</Border>

					<Border Style="{StaticResource AppearScale}"
                            Background="#111827"
                            CornerRadius="12"
                            Padding="20"
                            Width="260"
                            Margin="0,0,20,20">

						<StackPanel>
							<TextBlock Text="Топ приложение"
                                       Foreground="#9BAEC2"
                                       FontSize="15"
                                       TextWrapping="Wrap"/>
							<TextBlock Text="{Binding TopApplicationText}"
                                       Foreground="#2DC7FF"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Margin="0,5,0,0"
                                       TextTrimming="CharacterEllipsis"/>
						</StackPanel>
					</Border>

				</WrapPanel>

				<!-- Таблица Заголовок и Действия -->
				<Grid Grid.Row="1" Margin="0,0,0,10">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>

					<TextBlock Grid.Column="0"
                               Text="Активные приложения"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#2DC7FF"
                               VerticalAlignment="Center"/>

					<Button Grid.Column="1"
                            Content="📄 Экспорт в TXT"
                            Command="{Binding ExportCommand}"
                            Style="{StaticResource ReflineActionButton}"
                            Margin="0"
                            Padding="20 8"
                            Height="40"/>
				</Grid>

				<!-- Таблица -->
				<Border Grid.Row="2"
                        Background="#111827"
                        CornerRadius="12"
                        Padding="16"
                        HorizontalAlignment="Stretch">

					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="*"/>
						</Grid.RowDefinitions>

						<Grid Grid.Row="0" Margin="0,0,0,10">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="200"/>
							</Grid.ColumnDefinitions>
							<TextBlock Text="Приложение" Foreground="#9BAEC2" Grid.Column="0"/>
							<TextBlock Text="Время" Foreground="#9BAEC2" Grid.Column="1"/>
						</Grid>

                        <ItemsControl Grid.Row="1" ItemsSource="{Binding Activities}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,5,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="200"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding AppName}" Foreground="#DDE6F1" Grid.Column="0" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding DurationString}" Foreground="#DDE6F1" Grid.Column="1"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
					</Grid>

				</Border>

			</Grid>

		</StackPanel>
	</ScrollViewer>

</Page>
