<Window x:Class="Refline.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Смена пароля"
        Width="560"
        Height="640"
        MinWidth="540"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#0D1117">
    <Grid Margin="24">
        <Border Background="#161B22"
                BorderBrush="#2D333B"
                BorderThickness="1"
                CornerRadius="20"
                Padding="28">
            <DockPanel LastChildFill="True">
                <Grid DockPanel.Dock="Bottom"
                      Margin="0,24,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="Отмена"
                            Height="46"
                            Background="#22272E"
                            BorderBrush="#2D333B"
                            Foreground="White"
                            Command="{Binding CancelCommand}" />

                    <Button Grid.Column="2"
                            Content="Сохранить"
                            Height="46"
                            Command="{Binding SaveCommand}" />
                </Grid>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="True">
                    <StackPanel>
                        <TextBlock Text="Требуется смена пароля"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   TextWrapping="Wrap" />

                        <TextBlock Margin="0,10,0,0"
                                   Text="{Binding UserDisplayName, StringFormat=Для пользователя {0} выполнен вход с временным паролем.}"
                                   TextWrapping="Wrap"
                                   Foreground="#9AA4B2" />

                        <TextBlock Margin="0,6,0,24"
                                   Text="Пока пароль не будет изменён, доступ к основному интерфейсу приложения недоступен."
                                   TextWrapping="Wrap"
                                   Foreground="#9AA4B2" />

                        <TextBlock Text="Текущий пароль"
                                   Margin="0,0,0,6"
                                   Foreground="#9AA4B2" />
                        <PasswordBox x:Name="CurrentPasswordBox"
                                     MinHeight="44"
                                     Padding="10,8"
                                     PasswordChanged="CurrentPasswordBox_OnPasswordChanged" />

                        <TextBlock Text="Новый пароль"
                                   Margin="0,18,0,6"
                                   Foreground="#9AA4B2" />
                        <PasswordBox x:Name="NewPasswordBox"
                                     MinHeight="44"
                                     Padding="10,8"
                                     PasswordChanged="NewPasswordBox_OnPasswordChanged" />

                        <TextBlock Text="Подтверждение нового пароля"
                                   Margin="0,18,0,6"
                                   Foreground="#9AA4B2" />
                        <PasswordBox x:Name="ConfirmPasswordBox"
                                     MinHeight="44"
                                     Padding="10,8"
                                     PasswordChanged="ConfirmPasswordBox_OnPasswordChanged" />

                        <Border Margin="0,18,0,0"
                                Padding="12,10"
                                Background="#3D1C22"
                                BorderBrush="#DA3633"
                                BorderThickness="1"
                                CornerRadius="8"
                                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                            <TextBlock Text="{Binding ErrorMessage}"
                                       TextWrapping="Wrap"
                                       Foreground="#FFD1D1" />
                        </Border>

                        <TextBlock Margin="0,18,0,0"
                                   Text="Требования: заполните все поля. Новый пароль не должен совпадать с текущим."
                                   TextWrapping="Wrap"
                                   Foreground="#9AA4B2" />
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Window>
