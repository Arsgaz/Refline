<Window x:Class="Refline.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Смена пароля"
        Width="580"
        Height="720"
        MinWidth="560"
        MinHeight="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0B1220"
        FontFamily="Segoe UI">

    <Window.Resources>
        <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0B1220" Offset="0"/>
            <GradientStop Color="#10192B" Offset="1"/>
        </LinearGradientBrush>

        <SolidColorBrush x:Key="PanelBrush" Color="#111827"/>
        <SolidColorBrush x:Key="PanelActiveBrush" Color="#11263A"/>
        <SolidColorBrush x:Key="PanelHoverBrush" Color="#162033"/>
        <SolidColorBrush x:Key="BorderBrushNeutral" Color="#1E2A3D"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#DDE6F1"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#94A3B8"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2DC7FF"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#63D8FF"/>
        <SolidColorBrush x:Key="ErrorBackgroundBrush" Color="#31161C"/>
        <SolidColorBrush x:Key="ErrorBorderBrush" Color="#7F1D2A"/>
        <SolidColorBrush x:Key="ErrorTextBrush" Color="#F6C7CF"/>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushNeutral}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
        </Style>

        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="PasswordInputStyle" TargetType="PasswordBox">
            <Setter Property="MinHeight" Value="46"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="{StaticResource PanelActiveBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushNeutral}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="InputBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="#29425D"/>
                                <Setter TargetName="InputBorder" Property="Background" Value="{StaticResource PanelHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="InputBorder" Property="Background" Value="{StaticResource PanelActiveBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="InputBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="MinWidth" Value="152"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushNeutral}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource PanelHoverBrush}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource PanelActiveBrush}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Background" Value="{StaticResource PanelActiveBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBackgroundBrush}">
        <Grid Margin="24">
            <Border Style="{StaticResource CardBorderStyle}"
                    MaxWidth="620"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Padding="26">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Margin="0,0,0,20">
                        <TextBlock Text="Требуется смена пароля"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap"/>

                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding UserDisplayName, StringFormat=Вы вошли как {0} с временным паролем.}"
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"/>

                        <TextBlock Margin="0,6,0,0"
                                   Text="Чтобы продолжить работу, задайте новый постоянный пароль."
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1">
                        <TextBlock Text="Текущий пароль"
                                   Style="{StaticResource SectionLabelStyle}"/>
                        <PasswordBox x:Name="CurrentPasswordBox"
                                     Style="{StaticResource PasswordInputStyle}"
                                     PasswordChanged="CurrentPasswordBox_OnPasswordChanged"/>

                        <TextBlock Text="Новый пароль"
                                   Style="{StaticResource SectionLabelStyle}"
                                   Margin="0,16,0,8"/>
                        <PasswordBox x:Name="NewPasswordBox"
                                     Style="{StaticResource PasswordInputStyle}"
                                     PasswordChanged="NewPasswordBox_OnPasswordChanged"/>

                        <TextBlock Text="Подтверждение нового пароля"
                                   Style="{StaticResource SectionLabelStyle}"
                                   Margin="0,16,0,8"/>
                        <PasswordBox x:Name="ConfirmPasswordBox"
                                     Style="{StaticResource PasswordInputStyle}"
                                     PasswordChanged="ConfirmPasswordBox_OnPasswordChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2"
                                Margin="0,18,0,0">
                        <Border Padding="14,12"
                                Background="{StaticResource ErrorBackgroundBrush}"
                                BorderBrush="{StaticResource ErrorBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="{StaticResource ErrorTextBrush}"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <TextBlock Margin="0,12,0,0"
                                   Text="Заполните все поля. Новый пароль не должен совпадать с текущим."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <Grid Grid.Row="3"
                          Margin="0,22,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Отмена"
                                Command="{Binding CancelCommand}"
                                Style="{StaticResource ActionButtonStyle}"/>

                        <Button Grid.Column="2"
                                Content="Сохранить"
                                Command="{Binding SaveCommand}"
                                Style="{StaticResource PrimaryActionButtonStyle}"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>