<Window x:Class="Refline.Admin.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Refline Admin"
        Width="980"
        Height="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D1117" Offset="0" />
                <GradientStop Color="#101827" Offset="0.5" />
                <GradientStop Color="#0A1220" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.1*" />
            <ColumnDefinition Width="0.9*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="56">
            <StackPanel VerticalAlignment="Center"
                        MaxWidth="420">
                <Border Width="124"
                        Height="36"
                        CornerRadius="18"
                        Background="#16263A"
                        BorderBrush="{StaticResource AppBorderActiveBrush}"
                        BorderThickness="1"
                        HorizontalAlignment="Left">
                    <TextBlock Text="ADMIN PANEL"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="{StaticResource AppAccentBrush}" />
                </Border>

                <TextBlock Text="Refline Admin"
                           Margin="0,24,0,0"
                           FontSize="42"
                           FontWeight="SemiBold" />
                <TextBlock Text="Единая административная консоль для управления сотрудниками и будущей аналитикой."
                           Margin="0,18,0,0"
                           FontSize="17"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource AppMutedTextBrush}" />

                <Border Margin="0,36,0,0"
                        Style="{StaticResource CardBorderStyle}"
                        Padding="22">
                    <StackPanel>
                        <TextBlock Text="Что доступно сейчас"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,16,0,0"
                                   Text="• Авторизация через Refline.Api"
                                   Foreground="{StaticResource AppMutedTextBrush}" />
                        <TextBlock Margin="0,10,0,0"
                                   Text="• Просмотр списка сотрудников компании"
                                   Foreground="{StaticResource AppMutedTextBrush}" />
                        <TextBlock Margin="0,10,0,0"
                                   Text="• Готовый shell под аналитику, лицензии и правила"
                                   Foreground="{StaticResource AppMutedTextBrush}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1" Margin="40">
            <Border Width="380"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource SectionCardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Вход в систему"
                               FontSize="28"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Используйте учётную запись администратора или менеджера."
                               Margin="0,8,0,24"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource AppMutedTextBrush}" />

                    <TextBlock Text="Логин"
                               Style="{StaticResource InputLabelStyle}" />
                    <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Пароль"
                               Margin="0,18,0,6"
                               Style="{StaticResource InputLabelStyle}" />
                    <PasswordBox x:Name="PasswordInput"
                                 PasswordChanged="PasswordInput_OnPasswordChanged" />

                    <Border Margin="0,18,0,0"
                            Padding="12,10"
                            Background="#3D1C22"
                            BorderBrush="{StaticResource AppErrorBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   TextWrapping="Wrap"
                                   Foreground="#FFD1D1" />
                    </Border>

                    <Button Content="Войти"
                            Height="46"
                            Margin="0,24,0,0"
                            Command="{Binding LoginCommand}" />

                    <TextBlock Margin="0,18,0,0"
                               Text="Подключение к API: http://localhost:8080"
                               Foreground="{StaticResource AppMutedTextBrush}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
