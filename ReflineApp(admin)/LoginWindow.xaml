<Window x:Class="Refline.Admin.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Refline Admin"
        Width="460"
        Height="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Border Width="360"
                Padding="28"
                Background="{StaticResource AppPanelBrush}"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Refline Admin"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock Text="Вход в административную консоль"
                           Margin="0,6,0,20"
                           Foreground="{StaticResource AppMutedTextBrush}" />

                <TextBlock Text="Логин" />
                <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="Пароль" Margin="0,12,0,0" />
                <PasswordBox x:Name="PasswordInput"
                             PasswordChanged="PasswordInput_OnPasswordChanged" />

                <TextBlock Text="{Binding ErrorMessage}"
                           Margin="0,14,0,0"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource AppErrorBrush}" />

                <Button Content="Войти"
                        Height="40"
                        Margin="0,20,0,0"
                        Command="{Binding LoginCommand}" />

                <TextBlock Margin="0,16,0,0"
                           Foreground="{StaticResource AppMutedTextBrush}"
                           TextWrapping="Wrap">
                    Используйте пользователя с ролью Администратор или Менеджер.
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>
