<Window x:Class="Refline.Admin.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Refline Admin"
        Width="1040"
        Height="680"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Background="#0B1220"
        FontFamily="Segoe UI">
    <Window.Resources>
        <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0B1220" Offset="0" />
            <GradientStop Color="#10192B" Offset="1" />
        </LinearGradientBrush>

        <SolidColorBrush x:Key="PanelBrush" Color="#111827" />
        <SolidColorBrush x:Key="PanelActiveBrush" Color="#11263A" />
        <SolidColorBrush x:Key="PanelHoverBrush" Color="#162033" />
        <SolidColorBrush x:Key="BorderBrushNeutral" Color="#1E2A3D" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#DDE6F1" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2DC7FF" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#63D8FF" />
        <SolidColorBrush x:Key="ErrorBackgroundBrush" Color="#31161C" />
        <SolidColorBrush x:Key="ErrorBorderBrush" Color="#7F1D2A" />
        <SolidColorBrush x:Key="ErrorTextBrush" Color="#F6C7CF" />

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushNeutral}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="28" />
        </Style>

        <Style x:Key="FeatureCardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushNeutral}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="22" />
        </Style>

        <Style x:Key="FeatureItemBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelActiveBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushNeutral}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16,14" />
        </Style>

        <Style x:Key="InputLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="ReflineTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="54" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelActiveBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushNeutral}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="InputBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="InputBorder" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="#29425D" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="InputBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ReflinePasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="54" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelActiveBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushNeutral}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="InputBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="InputBorder" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="#29425D" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="InputBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushNeutral}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource PanelActiveBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Height" Value="50" />
            <Setter Property="Background" Value="{StaticResource PanelActiveBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBackgroundBrush}">
        <Grid Margin="44">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*" />
                <ColumnDefinition Width="0.85*" />
            </Grid.ColumnDefinitions>

            <!-- Левая часть -->
            <Grid Grid.Column="0" Margin="16,0,44,0">
                <StackPanel VerticalAlignment="Center"
                            MaxWidth="470">
                    <Border Width="152"
                            Height="42"
                            CornerRadius="21"
                            Background="{StaticResource PanelActiveBrush}"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="1"
                            HorizontalAlignment="Left">
                        <TextBlock Text="ADMIN CONSOLE"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}" />
                    </Border>

                    <TextBlock Text="Refline Admin"
                               Margin="0,26,0,0"
                               FontSize="46"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />

                    <TextBlock Text="Управляйте сотрудниками, просматривайте ключевые данные компании и поддерживайте рабочие правила в одном интерфейсе."
                               Margin="0,20,0,0"
                               FontSize="17"
                               LineHeight="28"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextSecondaryBrush}" />

                    <Border Margin="0,34,0,0"
                            Style="{StaticResource FeatureCardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Что доступно в консоли"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />

                            <Border Margin="0,16,0,0"
                                    Style="{StaticResource FeatureItemBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Сотрудники"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="Просмотр списка пользователей, ролей и состояния учётных записей."
                                               Margin="0,6,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,12,0,0"
                                    Style="{StaticResource FeatureItemBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Аналитика"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="Доступ к сводным показателям по сотрудникам и командам."
                                               Margin="0,6,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,12,0,0"
                                    Style="{StaticResource FeatureItemBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Лицензии и правила"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="Управление лицензиями компании и параметрами классификации активности."
                                               Margin="0,6,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Правая часть -->
            <Grid Grid.Column="1">
                <Border Width="420"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Style="{StaticResource PanelBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Вход в аккаунт"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />

                        <TextBlock Text="Используйте корпоративную учётную запись администратора или менеджера."
                                   Margin="0,8,0,24"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}" />

                        <TextBlock Text="Логин"
                                   Style="{StaticResource InputLabelStyle}" />
                        <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ReflineTextBoxStyle}" />

                        <TextBlock Text="Пароль"
                                   Margin="0,18,0,8"
                                   Style="{StaticResource InputLabelStyle}" />
                        <PasswordBox x:Name="PasswordInput"
                                     PasswordChanged="PasswordInput_OnPasswordChanged"
                                     Style="{StaticResource ReflinePasswordBoxStyle}" />

                        <Border Margin="0,18,0,0"
                                Padding="12,10"
                                Background="{StaticResource ErrorBackgroundBrush}"
                                BorderBrush="{StaticResource ErrorBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                            <TextBlock Text="{Binding ErrorMessage}"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource ErrorTextBrush}" />
                        </Border>

                        <Button Content="Войти"
                                Height="50"
                                Margin="0,24,0,0"
                                Command="{Binding LoginCommand}"
                                Style="{StaticResource PrimaryActionButtonStyle}" />

                        <TextBlock Margin="0,16,0,0"
                                   Text="После входа откроется административная консоль компании."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>