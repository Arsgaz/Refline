<Window x:Class="Refline.Admin.Views.TemporaryPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Временный пароль"
        Width="520"
        Height="420"
        MinWidth="520"
        MinHeight="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}">

    <Border Margin="18"
            Padding="22"
            Background="{StaticResource AppPanelBrush}"
            BorderBrush="{StaticResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="12">

        <DockPanel LastChildFill="True">

            <DockPanel DockPanel.Dock="Bottom"
                       Margin="0,20,0,0"
                       LastChildFill="False">

                <TextBlock Text="Сохраните пароль сейчас. Позже он не будет показан."
                           VerticalAlignment="Center"
                           Foreground="{StaticResource AppMutedTextBrush}"
                           TextWrapping="Wrap"
                           MaxWidth="220" />

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Width="130"
                            Height="42"
                            Margin="12,0,12,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="Скопировать"
                            Click="CopyButton_Click" />

                    <Button Width="110"
                            Height="42"
                            Content="Закрыть"
                            IsDefault="True"
                            Click="CloseButton_Click" />
                </StackPanel>
            </DockPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock x:Name="DialogTitleText"
                               FontSize="22"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />

                    <TextBlock x:Name="DialogSubtitleText"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource AppMutedTextBrush}" />

                    <Border Margin="0,20,0,0"
                            Padding="16"
                            Background="{StaticResource AppPanelElevatedBrush}"
                            BorderBrush="{StaticResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <StackPanel>
                            <TextBlock Text="Логин"
                                       Style="{StaticResource InputLabelStyle}" />

                            <TextBlock x:Name="LoginValueText"
                                       Margin="0,6,0,16"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />

                            <TextBlock Text="Временный пароль"
                                       Style="{StaticResource InputLabelStyle}" />

                            <TextBox x:Name="TemporaryPasswordTextBox"
                                     Margin="0,6,0,0"
                                     IsReadOnly="True"
                                     MinHeight="44"
                                     VerticalContentAlignment="Center"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

        </DockPanel>
    </Border>
</Window>