<Window x:Class="Refline.Admin.Views.TemporaryPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Временный пароль"
        Width="640"
        Height="450"
        MinWidth="640"
        MinHeight="450"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#0B1220">
    <Window.Resources>
        <SolidColorBrush x:Key="PageBaseBrush" Color="#0B1220" />
        <SolidColorBrush x:Key="PageSecondaryBrush" Color="#10192B" />
        <SolidColorBrush x:Key="PanelBrush" Color="#111827" />
        <SolidColorBrush x:Key="PanelHoverBrush" Color="#162033" />
        <SolidColorBrush x:Key="PanelActiveBrush" Color="#11263A" />
        <SolidColorBrush x:Key="BorderBrushNeutral" Color="#1E2A3D" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#DDE6F1" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2DC7FF" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#63D8FF" />

        <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0B1220" Offset="0" />
            <GradientStop Color="#10192B" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="DialogPanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushNeutral}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="24" />
        </Style>

        <Style x:Key="MetricLabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="DialogActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushNeutral}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource PanelActiveBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogActionButton}">
            <Setter Property="MinWidth" Value="148" />
            <Setter Property="Height" Value="44" />
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogActionButton}">
            <Setter Property="MinWidth" Value="132" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Background" Value="{StaticResource PanelActiveBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style x:Key="ReadOnlyPasswordTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="46" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelActiveBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushNeutral}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBackgroundBrush}">
        <Border Margin="20"
                Style="{StaticResource DialogPanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock x:Name="DialogTitleText"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"
                               TextWrapping="Wrap" />

                    <TextBlock x:Name="DialogSubtitleText"
                               Margin="0,10,0,0"
                               FontSize="14"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="0,22,0,18"
                        Padding="20"
                        Background="{StaticResource PanelActiveBrush}"
                        BorderBrush="{StaticResource BorderBrushNeutral}"
                        BorderThickness="1"
                        CornerRadius="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0"
                              Margin="0,0,0,18">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Логин"
                                       Style="{StaticResource MetricLabelTextStyle}" />

                            <TextBlock x:Name="LoginValueText"
                                       Grid.Row="1"
                                       Margin="0,8,0,0"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextWrapping="Wrap" />
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.ColumnSpan="2"
                                       Text="Временный пароль"
                                       Style="{StaticResource MetricLabelTextStyle}"
                                       Margin="0,0,0,8" />

                            <TextBox x:Name="TemporaryPasswordTextBox"
                                     Grid.Row="1"
                                     Grid.Column="0"
                                     Margin="0,0,14,0"
                                     IsReadOnly="True"
                                     Style="{StaticResource ReadOnlyPasswordTextBoxStyle}" />

                            <Button Grid.Row="1"
                                    Grid.Column="1"
                                    Content="Скопировать"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Click="CopyButton_Click" />
                        </Grid>
                    </Grid>
                </Border>

                <TextBlock Grid.Row="2"
                           Text="Сохраните пароль сейчас. Позже он не будет показан."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,22" />

                <StackPanel Grid.Row="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Закрыть"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            IsDefault="True"
                            Click="CloseButton_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
