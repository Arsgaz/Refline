<Window x:Class="Refline.Admin.Views.TemporaryPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Временный пароль"
        Width="520"
        Height="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}">
    <Border Margin="18"
            Padding="22"
            Background="{StaticResource AppPanelBrush}"
            BorderBrush="{StaticResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="DialogTitleText"
                       FontSize="22"
                       FontWeight="SemiBold" />

            <TextBlock x:Name="DialogSubtitleText"
                       Grid.Row="1"
                       Margin="0,10,0,0"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource AppMutedTextBrush}" />

            <Border Grid.Row="2"
                    Margin="0,20,0,0"
                    Padding="16"
                    Background="{StaticResource AppPanelElevatedBrush}"
                    BorderBrush="{StaticResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="Логин"
                               Style="{StaticResource InputLabelStyle}" />
                    <TextBlock x:Name="LoginValueText"
                               Margin="0,6,0,16"
                               FontSize="18"
                               FontWeight="SemiBold" />

                    <TextBlock Text="Временный пароль"
                               Style="{StaticResource InputLabelStyle}" />
                    <TextBox x:Name="TemporaryPasswordTextBox"
                             Margin="0,6,0,0"
                             IsReadOnly="True"
                             MinHeight="44" />
                </StackPanel>
            </Border>

            <DockPanel Grid.Row="3"
                       Margin="0,20,0,0">
                <TextBlock Text="Сохраните пароль сейчас. Позже он не будет показан."
                           VerticalAlignment="Center"
                           Foreground="{StaticResource AppMutedTextBrush}"
                           TextWrapping="Wrap" />
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Width="130"
                            Height="42"
                            Margin="12,0,12,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="Скопировать"
                            Click="CopyButton_Click" />
                    <Button Width="110"
                            Height="42"
                            Content="Закрыть"
                            IsDefault="True"
                            Click="CloseButton_Click" />
                </StackPanel>
            </DockPanel>
        </Grid>
    </Border>
</Window>
