<Window x:Class="Refline.Admin.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Смена пароля"
        Width="540"
        Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="28">
        <Border Style="{StaticResource SectionCardBorderStyle}">
            <StackPanel>
                <TextBlock Text="Требуется смена пароля"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock Margin="0,10,0,0"
                           Text="{Binding UserDisplayName, StringFormat=Для пользователя {0} выполнен первый вход с временным паролем.}"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource AppMutedTextBrush}" />
                <TextBlock Margin="0,6,0,24"
                           Text="Пока пароль не будет изменён, вход в административную панель недоступен."
                           TextWrapping="Wrap"
                           Foreground="{StaticResource AppMutedTextBrush}" />

                <TextBlock Text="Текущий пароль"
                           Style="{StaticResource InputLabelStyle}" />
                <PasswordBox x:Name="CurrentPasswordBox"
                             PasswordChanged="CurrentPasswordBox_OnPasswordChanged" />

                <TextBlock Text="Новый пароль"
                           Margin="0,18,0,6"
                           Style="{StaticResource InputLabelStyle}" />
                <PasswordBox x:Name="NewPasswordBox"
                             PasswordChanged="NewPasswordBox_OnPasswordChanged" />

                <TextBlock Text="Подтверждение нового пароля"
                           Margin="0,18,0,6"
                           Style="{StaticResource InputLabelStyle}" />
                <PasswordBox x:Name="ConfirmPasswordBox"
                             PasswordChanged="ConfirmPasswordBox_OnPasswordChanged" />

                <Border Margin="0,18,0,0"
                        Padding="12,10"
                        Background="#3D1C22"
                        BorderBrush="{StaticResource AppErrorBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               TextWrapping="Wrap"
                               Foreground="#FFD1D1" />
                </Border>

                <TextBlock Margin="0,18,0,0"
                           Text="Требования: заполните все поля, новый пароль не должен совпадать с текущим."
                           TextWrapping="Wrap"
                           Foreground="{StaticResource AppMutedTextBrush}" />

                <Grid Margin="0,28,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="Отмена"
                            Height="46"
                            Background="{StaticResource AppPanelElevatedBrush}"
                            BorderBrush="{StaticResource AppBorderBrush}"
                            Command="{Binding CancelCommand}" />

                    <Button Grid.Column="2"
                            Content="Сохранить"
                            Height="46"
                            Command="{Binding SaveCommand}" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
