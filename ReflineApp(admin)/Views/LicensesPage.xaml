<UserControl x:Class="Refline.Admin.Views.LicensesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,18">
            <StackPanel DockPanel.Dock="Left" MaxWidth="700">
                <TextBlock Text="Лицензия компании"
                           FontSize="22"
                           FontWeight="SemiBold" />
            </StackPanel>

            <Button DockPanel.Dock="Right"
                    Width="132"
                    Height="42"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Content="Обновить"
                    Command="{Binding RefreshCommand}" />
        </DockPanel>

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardBorderStyle}"
                    Margin="0,0,14,0">
                <StackPanel>
                    <TextBlock Text="Тип лицензии"
                               Foreground="{StaticResource AppMutedTextBrush}" />
                    <TextBlock Text="{Binding LicenseTypeDisplay}"
                               Margin="0,10,0,0"
                               FontSize="28"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding LicenseKindDescription}"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource AppMutedTextBrush}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource CardBorderStyle}"
                    Margin="0,0,14,0">
                <StackPanel>
                    <TextBlock Text="Статус"
                               Foreground="{StaticResource AppMutedTextBrush}" />
                    <TextBlock Text="{Binding LicenseStatusDisplay}"
                               Margin="0,10,0,0"
                               FontSize="28"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding RemainingTimeDisplay}"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource AppMutedTextBrush}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Устройства"
                               Foreground="{StaticResource AppMutedTextBrush}" />
                    <TextBlock Text="{Binding ActivatedDevicesDisplay}"
                               Margin="0,10,0,0"
                               FontSize="28"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding DeviceLimitDisplay, StringFormat=Лимит: {0}}"
                               Margin="0,8,0,0"
                               Foreground="{StaticResource AppMutedTextBrush}" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Margin="0,0,0,16"
                Padding="12,10"
                Background="{StaticResource AppPanelElevatedBrush}"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="Загрузка лицензии..."
                       Foreground="{StaticResource AppMutedTextBrush}" />
        </Border>

        <Grid Grid.Row="3">
            <Border Style="{StaticResource SectionCardBorderStyle}">
                <Grid>
                    <Grid Margin="0"
                          Visibility="{Binding HasLicense, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Margin="0,0,20,18"
                                   Text="Ключ лицензии"
                                   Foreground="{StaticResource AppMutedTextBrush}" />
                        <StackPanel Grid.Row="0"
                                    Grid.Column="1"
                                    Margin="0,0,0,18">
                            <DockPanel LastChildFill="False">
                                <TextBox MinHeight="44"
                                         IsReadOnly="True"
                                         Text="{Binding License.LicenseKey}"
                                         VerticalContentAlignment="Center" />
                                <Button Width="146"
                                        Margin="12,0,0,0"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Content="Скопировать ключ"
                                        Command="{Binding CopyLicenseKeyCommand}" />
                            </DockPanel>
                            <TextBlock Text="{Binding CopyStatusMessage}"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource AppMutedTextBrush}"
                                       Visibility="{Binding CopyStatusMessage, Converter={StaticResource StringToVisibilityConverter}}" />
                        </StackPanel>

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Margin="0,0,20,18"
                                   Text="Дата выдачи"
                                   Foreground="{StaticResource AppMutedTextBrush}" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Margin="0,0,0,18"
                                   Text="{Binding IssuedAtDisplay}"
                                   FontSize="16"
                                   FontWeight="SemiBold" />

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Margin="0,0,20,18"
                                   Text="Дата окончания"
                                   Foreground="{StaticResource AppMutedTextBrush}" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="0,0,0,18"
                                   Text="{Binding ExpiresAtDisplay}"
                                   FontSize="16"
                                   FontWeight="SemiBold" />

                        <TextBlock Grid.Row="3"
                                   Grid.Column="0"
                                   Margin="0,0,20,0"
                                   Text="Параметры"
                                   Foreground="{StaticResource AppMutedTextBrush}" />
                        <Grid Grid.Row="3"
                              Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource CardBorderStyle}"
                                    Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="ID лицензии"
                                               Foreground="{StaticResource AppMutedTextBrush}" />
                                    <TextBlock Text="{Binding License.LicenseId}"
                                               Margin="0,10,0,0"
                                               FontSize="20"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Style="{StaticResource CardBorderStyle}"
                                    Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="Лимит устройств"
                                               Foreground="{StaticResource AppMutedTextBrush}" />
                                    <TextBlock Text="{Binding DeviceLimitDisplay}"
                                               Margin="0,10,0,0"
                                               FontSize="20"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Активировано"
                                               Foreground="{StaticResource AppMutedTextBrush}" />
                                    <TextBlock Text="{Binding License.ActivatedDevicesCount}"
                                               Margin="0,10,0,0"
                                               FontSize="20"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <Border Padding="24"
                            Background="{StaticResource AppOverlayBrush}"
                            CornerRadius="10"
                            Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Не удалось загрузить лицензию"
                                       FontSize="20"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Margin="0,12,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource AppErrorBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Padding="24"
                            Background="{StaticResource AppOverlayBrush}"
                            CornerRadius="10"
                            Visibility="{Binding IsEmptyStateVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    MaxWidth="420">
                            <TextBlock Text="Активная лицензия не найдена"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Для компании ещё нет активной лицензии или она недоступна в текущем контуре администрирования."
                                       Margin="0,12,0,0"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource AppMutedTextBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
