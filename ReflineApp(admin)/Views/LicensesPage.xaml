<UserControl x:Class="Refline.Admin.Views.LicensesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0B1220">
    <UserControl.Resources>
        <SolidColorBrush x:Key="PageBaseBrush" Color="#0B1220" />
        <SolidColorBrush x:Key="PageSecondaryBrush" Color="#10192B" />
        <SolidColorBrush x:Key="PanelBrush" Color="#111827" />
        <SolidColorBrush x:Key="PanelHoverBrush" Color="#162033" />
        <SolidColorBrush x:Key="PanelActiveBrush" Color="#11263A" />
        <SolidColorBrush x:Key="BorderBrushNeutral" Color="#1E2A3D" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#DDE6F1" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2DC7FF" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#63D8FF" />

        <LinearGradientBrush x:Key="PageBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0B1220" Offset="0" />
            <GradientStop Color="#10192B" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="PagePanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushNeutral}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="SectionDescriptionTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="MetricLabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="MetricValueTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,10,0,0" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="ReflineActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushNeutral}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource PanelActiveBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ReflineActionButton}">
            <Setter Property="Height" Value="44" />
        </Style>

        <Style x:Key="DevicesGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="RowBackground" Value="{StaticResource PanelBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{StaticResource PageSecondaryBrush}" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrushNeutral}" />
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource BorderBrushNeutral}" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <WrapPanel Grid.Row="1" Margin="0,10,0,24">
                    <Border Style="{StaticResource PagePanelBorderStyle}"
                            Width="260"
                            Height="142"
                            Margin="0,0,16,16">
                        <StackPanel>
                            <TextBlock Text="Тип лицензии"
                                       Style="{StaticResource MetricLabelTextStyle}" />
                            <TextBlock Text="{Binding LicenseTypeDisplay}"
                                       Style="{StaticResource MetricValueTextStyle}" />
                            <TextBlock Text="{Binding LicenseKindDescription}"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PagePanelBorderStyle}"
                            Width="260"
                            Height="142"
                            Margin="0,0,16,16">
                        <StackPanel>
                            <TextBlock Text="Статус"
                                       Style="{StaticResource MetricLabelTextStyle}" />
                            <TextBlock Text="{Binding LicenseStatusDisplay}"
                                       Style="{StaticResource MetricValueTextStyle}" />
                            <TextBlock Text="{Binding RemainingTimeDisplay}"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PagePanelBorderStyle}"
                            Width="260"
                            Height="142"
                            Margin="0,0,16,16">
                        <StackPanel>
                            <TextBlock Text="Устройства"
                                       Style="{StaticResource MetricLabelTextStyle}" />
                            <TextBlock Text="{Binding ActivatedDevicesDisplay}"
                                       Style="{StaticResource MetricValueTextStyle}"
                                       Foreground="{StaticResource AccentBrush}" />
                            <TextBlock Text="{Binding DeviceLimitDisplay, StringFormat=Лимит: {0}}"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <Border Grid.Row="2"
                        Margin="0,0,0,20"
                        Padding="14,12"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushNeutral}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Загрузка лицензии..."
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </Border>

                <Grid Grid.Row="3">
                    <Border Style="{StaticResource PagePanelBorderStyle}">
                        <Grid>
                            <Grid Visibility="{Binding HasLicense, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Margin="0,0,0,24">
                                    <TextBlock Text="Ключ лицензии"
                                               Style="{StaticResource SectionTitleTextStyle}" />

                                    <TextBlock Text="Используйте ключ для проверки и передачи лицензии в пределах компании."
                                               Style="{StaticResource SectionDescriptionTextStyle}"
                                               Margin="0,0,0,14" />

                                    <DockPanel LastChildFill="False">
                                        <TextBox MinHeight="44"
                                                 IsReadOnly="True"
                                                 Text="{Binding License.LicenseKey}"
                                                 VerticalContentAlignment="Center"
                                                 Background="{StaticResource PanelActiveBrush}"
                                                 BorderBrush="{StaticResource BorderBrushNeutral}"
                                                 Foreground="{StaticResource TextPrimaryBrush}" />
                                        <Button MinWidth="176"
                                                Margin="12,0,0,0"
                                                Style="{StaticResource SecondaryActionButtonStyle}"
                                                Content="Скопировать ключ"
                                                Command="{Binding CopyLicenseKeyCommand}" />
                                    </DockPanel>

                                    <TextBlock Text="{Binding CopyStatusMessage}"
                                               Margin="0,8,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Visibility="{Binding CopyStatusMessage, Converter={StaticResource StringToVisibilityConverter}}" />
                                </StackPanel>

                                <Grid Grid.Row="1" Margin="0,0,0,24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Style="{StaticResource PagePanelBorderStyle}"
                                            Padding="18"
                                            Margin="0,0,12,0"
                                            Background="{StaticResource PanelActiveBrush}">
                                        <StackPanel>
                                            <TextBlock Text="Дата выдачи"
                                                       Style="{StaticResource MetricLabelTextStyle}" />
                                            <TextBlock Text="{Binding IssuedAtDisplay}"
                                                       Margin="0,10,0,0"
                                                       FontSize="20"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1"
                                            Style="{StaticResource PagePanelBorderStyle}"
                                            Padding="18"
                                            Margin="12,0,0,0"
                                            Background="{StaticResource PanelActiveBrush}">
                                        <StackPanel>
                                            <TextBlock Text="Дата окончания"
                                                       Style="{StaticResource MetricLabelTextStyle}" />
                                            <TextBlock Text="{Binding ExpiresAtDisplay}"
                                                       Margin="0,10,0,0"
                                                       FontSize="20"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                </Grid>

                                <Border Grid.Row="3"
                                        Margin="0,24,0,0"
                                        Style="{StaticResource PagePanelBorderStyle}"
                                        Padding="18"
                                        Background="{StaticResource PanelActiveBrush}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Margin="0,0,0,16">
                                            <TextBlock Text="Активированные устройства"
                                                       Style="{StaticResource SectionTitleTextStyle}" />
                                            <TextBlock Text="Список устройств текущей лицензии компании. Отозванные устройства не занимают слот лицензии."
                                                       Style="{StaticResource SectionDescriptionTextStyle}" />
                                        </StackPanel>

                                        <Border Grid.Row="1"
                                                Margin="0,0,0,16"
                                                Padding="14,12"
                                                Background="{StaticResource PanelBrush}"
                                                BorderBrush="{StaticResource BorderBrushNeutral}"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Visibility="{Binding HasDevicesError, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="{Binding DevicesErrorMessage}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>

                                        <Grid Grid.Row="2">
                                            <DataGrid ItemsSource="{Binding Devices}"
                                                      Style="{StaticResource DevicesGridStyle}"
                                                      Visibility="{Binding HasDevices, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                      IsReadOnly="True"
                                                      RowHeaderWidth="0"
                                                      MinRowHeight="46"
                                                      SelectionMode="Single">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Пользователь"
                                                                        Binding="{Binding UserFullName}"
                                                                        Width="1.4*" />
                                                    <DataGridTextColumn Header="Логин"
                                                                        Binding="{Binding UserLogin}"
                                                                        Width="*" />
                                                    <DataGridTextColumn Header="MachineName"
                                                                        Binding="{Binding MachineName}"
                                                                        Width="1.2*" />
                                                    <DataGridTextColumn Header="DeviceId"
                                                                        Binding="{Binding DeviceId}"
                                                                        Width="1.5*" />
                                                    <DataGridTextColumn Header="Активировано"
                                                                        Binding="{Binding ActivatedAtDisplay}"
                                                                        Width="*" />
                                                    <DataGridTextColumn Header="Last seen"
                                                                        Binding="{Binding LastSeenAtDisplay}"
                                                                        Width="*" />
                                                    <DataGridTextColumn Header="Статус"
                                                                        Binding="{Binding StatusDisplay}"
                                                                        Width="*" />
                                                    <DataGridTemplateColumn Header=""
                                                                            Width="1.1*">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Button Content="Отозвать устройство"
                                                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                                                        Command="{Binding DataContext.RevokeDeviceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        IsEnabled="{Binding CanRevoke}"
                                                                        MinWidth="150" />
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                </DataGrid.Columns>
                                            </DataGrid>

                                            <Border Padding="18"
                                                    Background="{StaticResource PanelBrush}"
                                                    BorderBrush="{StaticResource BorderBrushNeutral}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Visibility="{Binding IsDevicesEmptyStateVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="Для текущей лицензии пока нет активированных устройств."
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>

                            <Border Padding="24"
                                    Background="{StaticResource AppOverlayBrush}"
                                    CornerRadius="10"
                                    Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Не удалось загрузить лицензию"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding ErrorMessage}"
                                               Margin="0,12,0,0"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource AppErrorBrush}" />
                                </StackPanel>
                            </Border>

                            <Border Padding="24"
                                    Background="{StaticResource AppOverlayBrush}"
                                    CornerRadius="10"
                                    Visibility="{Binding IsEmptyStateVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            MaxWidth="420">
                                    <TextBlock Text="Активная лицензия не найдена"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="Для компании сейчас нет доступной активной лицензии или она недоступна в текущем контуре администрирования."
                                               Margin="0,12,0,0"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
