<UserControl x:Class="Refline.Admin.Views.EmployeeAnalyticsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0B1220">
    <UserControl.Resources>
        <SolidColorBrush x:Key="PageBaseBrush" Color="#0B1220" />
        <SolidColorBrush x:Key="PageSecondaryBrush" Color="#10192B" />
        <SolidColorBrush x:Key="PanelBrush" Color="#111827" />
        <SolidColorBrush x:Key="PanelHoverBrush" Color="#162033" />
        <SolidColorBrush x:Key="PanelActiveBrush" Color="#11263A" />
        <SolidColorBrush x:Key="BorderBrushNeutral" Color="#1E2A3D" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#DDE6F1" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2DC7FF" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#63D8FF" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#4ADE80" />
        <SolidColorBrush x:Key="DangerBrush" Color="#F87171" />
        <SolidColorBrush x:Key="OverlayBrush" Color="#CC0B1220" />

        <LinearGradientBrush x:Key="PageBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0B1220" Offset="0" />
            <GradientStop Color="#10192B" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="PagePanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushNeutral}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="SectionDescriptionTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="MetricLabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="MetricValueTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,10,0,0" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="ReflineActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushNeutral}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource PanelActiveBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PeriodToggleButton" TargetType="Button" BasedOn="{StaticResource ReflineActionButton}">
            <Setter Property="Height" Value="44" />
            <Setter Property="MinWidth" Value="96" />
        </Style>

        <Style x:Key="DayPeriodButtonStyle" TargetType="Button" BasedOn="{StaticResource PeriodToggleButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedPeriodKind}" Value="Day">
                    <Setter Property="Background" Value="{StaticResource PanelActiveBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WeekPeriodButtonStyle" TargetType="Button" BasedOn="{StaticResource PeriodToggleButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedPeriodKind}" Value="Week">
                    <Setter Property="Background" Value="{StaticResource PanelActiveBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MonthPeriodButtonStyle" TargetType="Button" BasedOn="{StaticResource PeriodToggleButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedPeriodKind}" Value="Month">
                    <Setter Property="Background" Value="{StaticResource PanelActiveBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CustomPeriodButtonStyle" TargetType="Button" BasedOn="{StaticResource PeriodToggleButton}">
            <Setter Property="MinWidth" Value="128" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedPeriodKind}" Value="Custom">
                    <Setter Property="Background" Value="{StaticResource PanelActiveBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ReflineActionButton}">
            <Setter Property="Height" Value="44" />
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ReflineActionButton}">
            <Setter Property="Height" Value="44" />
            <Setter Property="Background" Value="{StaticResource PanelActiveBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        </Style>

        <ControlTemplate x:Key="ReflineDatePickerToggleButton" TargetType="Button">
            <Border x:Name="ToggleBorder"
                    Background="{StaticResource PanelActiveBrush}"
                    BorderBrush="{StaticResource BorderBrushNeutral}"
                    BorderThickness="1"
                    CornerRadius="0,10,10,0">
                <TextBlock Text="▾"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                    <Setter TargetName="ToggleBorder" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="DarkDatePickerTextBoxStyle" TargetType="{x:Type DatePickerTextBox}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelActiveBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushNeutral}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DatePickerTextBox}">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10,0,0,10">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="0"
                                              Padding="14,10"
                                              VerticalAlignment="Center"
                                              HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Hidden"
                                              Foreground="{TemplateBinding Foreground}" />
                                <TextBlock x:Name="Watermark"
                                           Margin="14,10"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Opacity="0.8"
                                           Visibility="Collapsed"
                                           Text="{TemplateBinding Tag}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelActiveBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushNeutral}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="44" />
            <Setter Property="MinWidth" Value="160" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>

                            <DatePickerTextBox x:Name="PART_TextBox"
                                               Grid.Column="0"
                                               Style="{StaticResource DarkDatePickerTextBoxStyle}"
                                               Background="{TemplateBinding Background}"
                                               Foreground="{TemplateBinding Foreground}"
                                               BorderBrush="{TemplateBinding BorderBrush}"
                                               BorderThickness="{TemplateBinding BorderThickness}"
                                               VerticalContentAlignment="Center" />

                            <Button x:Name="PART_Button"
                                    Grid.Column="1"
                                    Focusable="False"
                                    Template="{StaticResource ReflineDatePickerToggleButton}" />

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="Fade">
                                <Border Background="#FFFFFF"
                                        BorderBrush="{StaticResource BorderBrushNeutral}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <Calendar x:Name="PART_Calendar"
                                              Style="{StaticResource ReflineCalendarStyle}" />
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource PagePanelBorderStyle}"
                        Margin="0,0,0,24"
                        Padding="24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="260" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Margin="0,0,24,0">

                            <Border Background="{StaticResource PanelActiveBrush}"
                                    BorderBrush="{StaticResource BorderBrushNeutral}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="18,16">
                                <StackPanel>
                                    <TextBlock Text="Сотрудник"
                                               Style="{StaticResource MetricLabelTextStyle}" />
                                    <TextBlock Text="{Binding EmployeeHeader}"
                                               Margin="0,10,0,0"
                                               FontSize="26"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding EmployeeSubheader}"
                                               Margin="0,8,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Style="{StaticResource PagePanelBorderStyle}"
                                Padding="18"
                                Background="#101A2C"
                                VerticalAlignment="Stretch">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Статус сотрудника"
                                           Style="{StaticResource MetricLabelTextStyle}" />
                                <TextBlock Text="{Binding EmployeeStatusDisplay}"
                                           Margin="0,10,0,0"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="Статус помогает быстро понять, доступна ли аналитика и актуальны ли текущие данные по сотруднику."
                                           Margin="0,10,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Style="{StaticResource PagePanelBorderStyle}"
                        Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="Период и фильтры"
                                   Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Text="Выберите период, настройте даты и обновите аналитику по сотруднику."
                                   Style="{StaticResource SectionDescriptionTextStyle}"
                                   Margin="0,0,0,16" />

                        <WrapPanel>
                            <Button Content="День"
                                    Width="96"
                                    Margin="0,0,10,10"
                                    Style="{StaticResource DayPeriodButtonStyle}"
                                    Command="{Binding SetDayPeriodCommand}" />
                            <Button Content="Неделя"
                                    Width="108"
                                    Margin="0,0,10,10"
                                    Style="{StaticResource WeekPeriodButtonStyle}"
                                    Command="{Binding SetWeekPeriodCommand}" />
                            <Button Content="Месяц"
                                    Width="108"
                                    Margin="0,0,10,10"
                                    Style="{StaticResource MonthPeriodButtonStyle}"
                                    Command="{Binding SetMonthPeriodCommand}" />
                            <Button Content="Произвольно"
                                    Width="136"
                                    Margin="0,0,18,10"
                                    Style="{StaticResource CustomPeriodButtonStyle}"
                                    Command="{Binding SetCustomPeriodCommand}" />

                            <StackPanel Margin="0,0,16,10"
                                        Visibility="{Binding IsReferenceDateVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="Опорная дата"
                                           Style="{StaticResource MetricLabelTextStyle}"
                                           Margin="0,0,0,6" />
                                <DatePicker SelectedDate="{Binding ReferenceDate, Mode=TwoWay}"
                                            Style="{StaticResource DarkDatePickerStyle}" />
                            </StackPanel>

                            <StackPanel Margin="0,0,12,10"
                                        Visibility="{Binding IsCustomDatesVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="С"
                                           Style="{StaticResource MetricLabelTextStyle}"
                                           Margin="0,0,0,6" />
                                <DatePicker SelectedDate="{Binding CustomStartDate, Mode=TwoWay}"
                                            Style="{StaticResource DarkDatePickerStyle}" />
                            </StackPanel>

                            <StackPanel Margin="0,0,16,10"
                                        Visibility="{Binding IsCustomDatesVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="По"
                                           Style="{StaticResource MetricLabelTextStyle}"
                                           Margin="0,0,0,6" />
                                <DatePicker SelectedDate="{Binding CustomEndDate, Mode=TwoWay}"
                                            Style="{StaticResource DarkDatePickerStyle}" />
                            </StackPanel>

                            <StackPanel Margin="0,0,16,10"
                                        Visibility="{Binding IsReferenceDateVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="Диапазон"
                                           Style="{StaticResource MetricLabelTextStyle}"
                                           Margin="0,0,0,6" />
                                <Border Background="{StaticResource PanelActiveBrush}"
                                        BorderBrush="{StaticResource BorderBrushNeutral}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="14,10"
                                        MinHeight="44"
                                        MinWidth="220">
                                    <TextBlock Text="{Binding PeriodLabel}"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,12,10">
                                <Button Width="44"
                                        Content="←"
                                        Margin="0,0,8,0"
                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                        Command="{Binding PreviousPeriodCommand}" />
                                <Button Width="44"
                                        Content="→"
                                        Margin="0,0,8,0"
                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                        Command="{Binding NextPeriodCommand}" />
                                <Button Width="100"
                                        Content="Сегодня"
                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                        Command="{Binding TodayCommand}" />
                            </StackPanel>

                            <Button Width="132"
                                    Margin="0,0,0,10"
                                    Content="Обновить"
                                    VerticalAlignment="Bottom"
                                    Style="{StaticResource PrimaryActionButtonStyle}"
                                    Command="{Binding LoadCommand}" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <WrapPanel Grid.Row="2"
                           Margin="0,0,0,24">
                    <Border Style="{StaticResource PagePanelBorderStyle}"
                            Width="260"
                            Height="132"
                            Margin="0,0,16,16">
                        <StackPanel>
                            <TextBlock Text="Общее время"
                                       Style="{StaticResource MetricLabelTextStyle}" />
                            <TextBlock Text="{Binding TotalTrackedDisplay}"
                                       Style="{StaticResource MetricValueTextStyle}"
                                       Foreground="{StaticResource AccentBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PagePanelBorderStyle}"
                            Width="260"
                            Height="132"
                            Margin="0,0,16,16">
                        <StackPanel>
                            <TextBlock Text="Активное время"
                                       Style="{StaticResource MetricLabelTextStyle}" />
                            <TextBlock Text="{Binding ActiveDisplay}"
                                       Style="{StaticResource MetricValueTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PagePanelBorderStyle}"
                            Width="260"
                            Height="132"
                            Margin="0,0,16,16">
                        <StackPanel>
                            <TextBlock Text="Продуктивное время"
                                       Style="{StaticResource MetricLabelTextStyle}" />
                            <TextBlock Text="{Binding ProductiveDisplay}"
                                       Style="{StaticResource MetricValueTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PagePanelBorderStyle}"
                            Width="260"
                            Height="132"
                            Margin="0,0,16,16">
                        <StackPanel>
                            <TextBlock Text="Время бездействия"
                                       Style="{StaticResource MetricLabelTextStyle}" />
                            <TextBlock Text="{Binding IdleDisplay}"
                                       Style="{StaticResource MetricValueTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PagePanelBorderStyle}"
                            Width="260"
                            Height="132"
                            Margin="0,0,16,16">
                        <StackPanel>
                            <TextBlock Text="Топ приложение"
                                       Style="{StaticResource MetricLabelTextStyle}" />
                            <TextBlock Text="{Binding TopApplicationName}"
                                       Margin="0,10,0,0"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PagePanelBorderStyle}"
                            Width="260"
                            Height="132"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Топ категория"
                                       Style="{StaticResource MetricLabelTextStyle}" />
                            <TextBlock Text="{Binding TopCategory}"
                                       Margin="0,10,0,0"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <Border Grid.Row="3"
                        Margin="0,0,0,18"
                        Padding="14,12"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushNeutral}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Загрузка аналитики сотрудника..."
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </Border>

                <Border Grid.Row="4"
                        Margin="0,0,0,18"
                        Padding="16,14"
                        Background="#3D1C22"
                        BorderBrush="{StaticResource DangerBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Не удалось загрузить аналитику"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="#FFD1D1" />
                    </StackPanel>
                </Border>

                <Grid Grid.Row="5">
                    <Border Style="{StaticResource PagePanelBorderStyle}"
                            Visibility="{Binding IsEmptyStateVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    MaxWidth="440">
                            <TextBlock Text="За выбранный период активность не найдена"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       HorizontalAlignment="Center"
                                       MaxWidth="420"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Попробуйте изменить период или выбрать другую дату. Когда данные появятся, аналитика отобразится здесь автоматически."
                                       Margin="0,12,0,0"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>

                    <Grid Visibility="{Binding HasAnyData, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Style="{StaticResource PagePanelBorderStyle}"
                                Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Text="Активность по дням"
                                           Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock Text="Суммарное время активности внутри выбранного периода."
                                           Style="{StaticResource SectionDescriptionTextStyle}"
                                           Margin="0,0,0,18" />

                                <ItemsControl ItemsSource="{Binding DailyBuckets}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="1" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="6,0,6,0"
                                                  VerticalAlignment="Bottom">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="130" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0"
                                                           Text="{Binding TotalDisplay}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,0,0,10"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                                <Border Grid.Row="1"
                                                        Width="34"
                                                        Height="{Binding BarHeight}"
                                                        VerticalAlignment="Bottom"
                                                        HorizontalAlignment="Center"
                                                        Background="{StaticResource AccentBrush}"
                                                        CornerRadius="8,8,0,0" />
                                                <TextBlock Grid.Row="2"
                                                           Text="{Binding Label}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,10,0,0"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource PagePanelBorderStyle}"
                                    Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="Топ приложений"
                                               Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Text="Приложения, в которых сотрудник провёл больше всего времени."
                                               Style="{StaticResource SectionDescriptionTextStyle}"
                                               Margin="0,0,0,18" />
                                    <ItemsControl ItemsSource="{Binding Applications}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,10"
                                                        Padding="12"
                                                        Background="{StaticResource PanelActiveBrush}"
                                                        BorderBrush="{StaticResource BorderBrushNeutral}"
                                                        BorderThickness="1"
                                                        CornerRadius="8">
                                                    <DockPanel>
                                                        <TextBlock Text="{Binding DurationDisplay}"
                                                                   DockPanel.Dock="Right"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                                        <TextBlock Text="{Binding Name}"
                                                                   TextWrapping="Wrap"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                                    </DockPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Style="{StaticResource PagePanelBorderStyle}"
                                    Margin="12,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Категории"
                                               Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Text="Распределение активности по рабочим категориям за выбранный период."
                                               Style="{StaticResource SectionDescriptionTextStyle}"
                                               Margin="0,0,0,18" />
                                    <ItemsControl ItemsSource="{Binding Categories}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,10"
                                                        Padding="12"
                                                        Background="{StaticResource PanelActiveBrush}"
                                                        BorderBrush="{StaticResource BorderBrushNeutral}"
                                                        BorderThickness="1"
                                                        CornerRadius="8">
                                                    <DockPanel>
                                                        <TextBlock Text="{Binding DurationDisplay}"
                                                                   DockPanel.Dock="Right"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                                        <TextBlock Text="{Binding Name}"
                                                                   TextWrapping="Wrap"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                                    </DockPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>

                <StackPanel Grid.Row="6"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            Margin="0,20,0,0">
                    <Button Content="Назад к списку"
                            MinWidth="168"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Command="{Binding BackCommand}" />
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
