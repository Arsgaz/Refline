<UserControl x:Class="Refline.Admin.Views.PlaceholderPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource SectionCardBorderStyle}">
        <StackPanel MaxWidth="520">
            <TextBlock Text="{Binding Title}"
                       FontSize="24"
                       FontWeight="SemiBold" />
            <TextBlock Text="{Binding Description}"
                       Margin="0,12,0,0"
                       TextWrapping="Wrap"
                       FontSize="15"
                       Foreground="{StaticResource AppMutedTextBrush}" />
            <Border Margin="0,24,0,0"
                    Padding="14,12"
                    Background="{StaticResource AppPanelElevatedBrush}"
                    BorderBrush="{StaticResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <TextBlock Text="Функциональность этого раздела намеренно отложена до следующего этапа."
                           TextWrapping="Wrap"
                           Foreground="{StaticResource AppMutedTextBrush}" />
            </Border>
        </StackPanel>
    </Border>
</UserControl>
