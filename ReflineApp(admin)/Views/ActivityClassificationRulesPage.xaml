<UserControl x:Class="Refline.Admin.Views.ActivityClassificationRulesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,18">
            <StackPanel DockPanel.Dock="Left" MaxWidth="640">
                <TextBlock Text="Правила классификации активности"
                           FontSize="22"
                           FontWeight="SemiBold" />
                <TextBlock Text="Компания может задавать свои шаблоны приложений и заголовков окон для фиксированных категорий активности."
                           Margin="0,8,0,0"
                           Foreground="{StaticResource AppMutedTextBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Width="156"
                        Height="42"
                        Margin="0,0,12,0"
                        Content="Добавить правило"
                        Command="{Binding CreateRuleCommand}" />
                <Button Width="148"
                        Height="42"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Content="Обновить"
                        Command="{Binding RefreshCommand}" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardBorderStyle}"
                    Margin="0,0,14,0">
                <StackPanel>
                    <TextBlock Text="Всего правил"
                               Foreground="{StaticResource AppMutedTextBrush}" />
                    <TextBlock Text="{Binding Rules.Count}"
                               Margin="0,10,0,0"
                               FontSize="28"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource CardBorderStyle}"
                    Margin="0,0,14,0">
                <StackPanel>
                    <TextBlock Text="Активных"
                               Foreground="{StaticResource AppMutedTextBrush}" />
                    <TextBlock Text="{Binding EnabledRulesCount}"
                               Margin="0,10,0,0"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AppSuccessBrush}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Статус загрузки"
                               Foreground="{StaticResource AppMutedTextBrush}" />
                    <TextBlock Text="{Binding RulesCountText}"
                               Margin="0,10,0,0"
                               FontSize="18"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding DisabledRulesCount, StringFormat=Отключено правил: {0}}"
                               Margin="0,10,0,0"
                               Foreground="{StaticResource AppMutedTextBrush}" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Margin="0,0,0,16"
                Padding="12,10"
                Background="{StaticResource AppPanelElevatedBrush}"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="Загрузка правил..."
                       Foreground="{StaticResource AppMutedTextBrush}" />
        </Border>

        <Grid Grid.Row="3">
            <Border Style="{StaticResource SectionCardBorderStyle}">
                <Grid>
                    <DataGrid ItemsSource="{Binding Rules}"
                              SelectedItem="{Binding SelectedRule, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="AppName"
                                                Binding="{Binding AppNamePattern}"
                                                Width="1.9*" />
                            <DataGridTextColumn Header="WindowTitle"
                                                Binding="{Binding WindowTitlePatternDisplay}"
                                                Width="2.1*" />
                            <DataGridTextColumn Header="Категория"
                                                Binding="{Binding CategoryDisplay}"
                                                Width="1.3*" />
                            <DataGridTextColumn Header="Приоритет"
                                                Binding="{Binding Priority}"
                                                Width="0.9*" />
                            <DataGridTemplateColumn Header="Статус"
                                                    Width="1.1*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border x:Name="StatusPill"
                                                Style="{StaticResource PillBorderStyle}"
                                                Background="#152A1D"
                                                BorderBrush="{StaticResource AppSuccessBrush}">
                                            <TextBlock x:Name="StatusText"
                                                       Text="{Binding StatusDisplay}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource AppSuccessBrush}" />
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                <Setter TargetName="StatusPill" Property="Background" Value="#3B1F24" />
                                                <Setter TargetName="StatusPill" Property="BorderBrush" Value="{StaticResource AppWarningBrush}" />
                                                <Setter TargetName="StatusText" Property="Foreground" Value="{StaticResource AppWarningBrush}" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Действия"
                                                    Width="330">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid HorizontalAlignment="Left">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Button Grid.Column="0"
                                                    Height="34"
                                                    Margin="0,0,8,0"
                                                    Content="Изменить"
                                                    Style="{StaticResource CompactSecondaryButtonStyle}"
                                                    Command="{Binding DataContext.EditRuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Grid.Column="1"
                                                    Height="34"
                                                    Margin="0,0,8,0"
                                                    MinWidth="112"
                                                    Content="{Binding ToggleActionDisplay}"
                                                    Style="{StaticResource CompactSecondaryButtonStyle}"
                                                    Command="{Binding DataContext.ToggleRuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Grid.Column="2"
                                                    Height="34"
                                                    Content="Удалить"
                                                    Style="{StaticResource CompactSecondaryButtonStyle}"
                                                    Command="{Binding DataContext.DeleteRuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" />
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Padding="24"
                            Background="{StaticResource AppOverlayBrush}"
                            CornerRadius="10"
                            Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Не удалось загрузить правила"
                                       FontSize="20"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Margin="0,12,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource AppErrorBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Padding="24"
                            Background="{StaticResource AppOverlayBrush}"
                            CornerRadius="10"
                            Visibility="{Binding IsEmptyStateVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    MaxWidth="420">
                            <TextBlock Text="Правил пока нет"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Добавьте первое правило классификации, чтобы компания могла хранить свои шаблоны приложений и окон."
                                       Margin="0,12,0,0"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource AppMutedTextBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
