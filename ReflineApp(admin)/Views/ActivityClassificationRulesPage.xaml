<UserControl x:Class="Refline.Admin.Views.ActivityClassificationRulesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0B1220">
    <UserControl.Resources>
        <SolidColorBrush x:Key="PageBaseBrush" Color="#0B1220" />
        <SolidColorBrush x:Key="PageSecondaryBrush" Color="#10192B" />
        <SolidColorBrush x:Key="PanelBrush" Color="#111827" />
        <SolidColorBrush x:Key="PanelHoverBrush" Color="#162033" />
        <SolidColorBrush x:Key="PanelActiveBrush" Color="#11263A" />
        <SolidColorBrush x:Key="BorderBrushNeutral" Color="#1E2A3D" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#DDE6F1" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2DC7FF" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#63D8FF" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#4ADE80" />
        <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B" />
        <SolidColorBrush x:Key="DangerBrush" Color="#F87171" />
        <SolidColorBrush x:Key="OverlayBrush" Color="#CC0B1220" />

        <LinearGradientBrush x:Key="PageBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0B1220" Offset="0" />
            <GradientStop Color="#10192B" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="PagePanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushNeutral}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <Style x:Key="MetricLabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="MetricValueTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,10,0,0" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="SectionDescriptionTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="ReflineActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushNeutral}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource PanelActiveBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ReflineActionButton}">
            <Setter Property="MinWidth" Value="184" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Background" Value="{StaticResource PanelActiveBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ReflineActionButton}">
            <Setter Property="MinWidth" Value="136" />
            <Setter Property="Height" Value="44" />
        </Style>

        <Style x:Key="CompactActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ReflineActionButton}">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="RulesDataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserReorderColumns" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="CanUserSortColumns" Value="True" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrushNeutral}" />
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource BorderBrushNeutral}" />
            <Setter Property="RowBackground" Value="#0F172A" />
            <Setter Property="AlternatingRowBackground" Value="#101B2F" />
            <Setter Property="AlternationCount" Value="2" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="12,10" />
                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                        <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource PanelActiveBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#162033" />
                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushNeutral}" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                        <Setter Property="Padding" Value="12,12" />
                        <Setter Property="Height" Value="44" />
                        <Setter Property="FontSize" Value="13" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="HorizontalContentAlignment" Value="Left" />
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="#0F172A" />
                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushNeutral}" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                        <Setter Property="MinHeight" Value="60" />
                        <Setter Property="SnapsToDevicePixels" Value="True" />
                        <Style.Triggers>
                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                <Setter Property="Background" Value="#101B2F" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource PanelHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource PanelActiveBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource PagePanelBorderStyle}"
                        Padding="24"
                        Margin="0,0,0,24"
                        Background="#101827">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0"
                                    Grid.Column="0"
                                    Margin="0,0,24,0">
                            <TextBlock Text="Правила классификации активности"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}"
                                       Margin="0,0,0,8" />
                            <TextBlock Text="Настраивайте шаблоны приложений и заголовков окон, чтобы классификация активности оставалась точной и предсказуемой."
                                       FontSize="15"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Grid.Row="0"
                                    Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top">
                            <Button MinWidth="188"
                                    Margin="0,0,12,0"
                                    Content="Добавить правило"
                                    Style="{StaticResource PrimaryActionButtonStyle}"
                                    Command="{Binding CreateRuleCommand}" />
                            <Button Content="Обновить"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Command="{Binding RefreshCommand}" />
                        </StackPanel>

                        <Border Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Margin="0,18,0,0"
                                Padding="16,14"
                                Background="{StaticResource PanelActiveBrush}"
                                BorderBrush="{StaticResource BorderBrushNeutral}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Загрузка правил..."
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </Border>
                    </Grid>
                </Border>

                <UniformGrid Grid.Row="1"
                             Columns="3"
                             Margin="0,0,0,24">
                    <Border Style="{StaticResource PagePanelBorderStyle}"
                            Height="138"
                            Margin="0,0,16,0">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Всего правил"
                                       Style="{StaticResource MetricLabelTextStyle}" />
                            <TextBlock Text="{Binding Rules.Count}"
                                       Style="{StaticResource MetricValueTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PagePanelBorderStyle}"
                            Height="138"
                            Margin="0,0,16,0">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Активных"
                                       Style="{StaticResource MetricLabelTextStyle}" />
                            <TextBlock Text="{Binding EnabledRulesCount}"
                                       Style="{StaticResource MetricValueTextStyle}"
                                       Foreground="{StaticResource AccentBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PagePanelBorderStyle}"
                            Height="138">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Статус загрузки"
                                       Style="{StaticResource MetricLabelTextStyle}" />
                            <TextBlock Text="{Binding RulesCountText}"
                                       Margin="0,10,0,0"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding DisabledRulesCount, StringFormat=Отключено правил: {0}}"
                                       Margin="0,10,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Border Grid.Row="2"
                        Style="{StaticResource PagePanelBorderStyle}"
                        Margin="0,0,0,18"
                        Padding="22,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Margin="0,0,20,0">
                            <TextBlock Text="Список правил"
                                       Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="Проверяйте шаблоны, приоритеты и статус правил в единой рабочей области."
                                       Style="{StaticResource SectionDescriptionTextStyle}" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Padding="12,8"
                                Background="{StaticResource PanelActiveBrush}"
                                BorderBrush="{StaticResource BorderBrushNeutral}"
                                BorderThickness="1"
                                CornerRadius="10"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding Rules.Count, StringFormat=Записей: {0}}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold" />
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="3">
                    <Border Style="{StaticResource PagePanelBorderStyle}"
                            Padding="0">
                        <Grid>
                            <DataGrid ItemsSource="{Binding Rules}"
                                      SelectedItem="{Binding SelectedRule, Mode=TwoWay}"
                                      Style="{StaticResource RulesDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="AppName"
                                                        Binding="{Binding AppNamePattern}"
                                                        Width="1.55*" />
                                    <DataGridTextColumn Header="WindowTitle"
                                                        Binding="{Binding WindowTitlePatternDisplay}"
                                                        Width="1.95*" />
                                    <DataGridTextColumn Header="Категория"
                                                        Binding="{Binding CategoryDisplay}"
                                                        Width="1.2*" />
                                    <DataGridTextColumn Header="Приоритет"
                                                        Binding="{Binding Priority}"
                                                        Width="0.8*" />
                                    <DataGridTemplateColumn Header="Статус"
                                                            Width="1.0*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border x:Name="StatusPill"
                                                        Padding="12,6"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        Background="#152A1D"
                                                        BorderBrush="{StaticResource SuccessBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="999">
                                                    <TextBlock x:Name="StatusText"
                                                               Text="{Binding StatusDisplay}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource SuccessBrush}" />
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                        <Setter TargetName="StatusPill" Property="Background" Value="#3B1F24" />
                                                        <Setter TargetName="StatusPill" Property="BorderBrush" Value="{StaticResource WarningBrush}" />
                                                        <Setter TargetName="StatusText" Property="Foreground" Value="{StaticResource WarningBrush}" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Действия"
                                                            Width="352">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid HorizontalAlignment="Left"
                                                      VerticalAlignment="Center">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="88" />
                                                        <ColumnDefinition Width="116" />
                                                        <ColumnDefinition Width="84" />
                                                    </Grid.ColumnDefinitions>

                                                    <Button Grid.Column="0"
                                                            Margin="0,0,8,0"
                                                            Content="Изменить"
                                                            Style="{StaticResource CompactActionButtonStyle}"
                                                            Command="{Binding DataContext.EditRuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}" />
                                                    <Button Grid.Column="1"
                                                            Margin="0,0,8,0"
                                                            Content="{Binding ToggleActionDisplay}"
                                                            Style="{StaticResource CompactActionButtonStyle}"
                                                            Command="{Binding DataContext.ToggleRuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}" />
                                                    <Button Grid.Column="2"
                                                            Content="Удалить"
                                                            Style="{StaticResource CompactActionButtonStyle}"
                                                            BorderBrush="#4B2430"
                                                            Foreground="{StaticResource DangerBrush}"
                                                            Command="{Binding DataContext.DeleteRuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}" />
                                                </Grid>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border Padding="28"
                                    Background="{StaticResource OverlayBrush}"
                                    CornerRadius="12"
                                    Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel VerticalAlignment="Center"
                                            MaxWidth="480">
                                    <TextBlock Text="Не удалось загрузить правила"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding ErrorMessage}"
                                               Margin="0,12,0,0"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource DangerBrush}" />
                                </StackPanel>
                            </Border>

                            <Border Padding="28"
                                    Background="{StaticResource OverlayBrush}"
                                    CornerRadius="12"
                                    Visibility="{Binding IsEmptyStateVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            MaxWidth="440">
                                    <TextBlock Text="Правил пока нет"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="Добавьте первое правило, чтобы команда могла автоматически относить активность к нужным категориям."
                                               Margin="0,12,0,0"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
