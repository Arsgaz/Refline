<UserControl x:Class="Refline.Admin.Views.EmployeesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0B1220">
    <UserControl.Resources>
        <SolidColorBrush x:Key="PageBaseBrush" Color="#0B1220" />
        <SolidColorBrush x:Key="PageSecondaryBrush" Color="#10192B" />
        <SolidColorBrush x:Key="PanelBrush" Color="#111827" />
        <SolidColorBrush x:Key="PanelHoverBrush" Color="#162033" />
        <SolidColorBrush x:Key="PanelActiveBrush" Color="#11263A" />
        <SolidColorBrush x:Key="BorderBrushNeutral" Color="#1E2A3D" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#DDE6F1" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2DC7FF" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#63D8FF" />

        <LinearGradientBrush x:Key="PageBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0B1220" Offset="0" />
            <GradientStop Color="#10192B" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="PagePanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushNeutral}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="SectionDescriptionTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="MetricLabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="MetricValueTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="PageSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushNeutral}" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="PagePrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="{StaticResource PanelActiveBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style x:Key="TableActionButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactSecondaryButtonStyle}">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushNeutral}" />
            <Setter Property="Background" Value="{StaticResource PanelActiveBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="Transparent"
                        Margin="0,0,0,12">
                    <TextBlock Text="Управляйте сотрудниками компании, быстро находите нужные записи и выполняйте основные действия из одного списка."
                               FontSize="15"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <Border Grid.Row="1"
                        Style="{StaticResource PagePanelBorderStyle}"
                        Margin="0,0,0,20">
                    <DockPanel LastChildFill="False">
                        <Border DockPanel.Dock="Left"
                                Style="{StaticResource PagePanelBorderStyle}"
                                Background="{StaticResource PanelActiveBrush}"
                                Padding="18"
                                Margin="0,0,18,0"
                                MinWidth="240">
                            <StackPanel>
                                <TextBlock Text="Найдено сотрудников"
                                           Style="{StaticResource MetricLabelTextStyle}" />
                                <TextBlock Text="{Binding Users.Count}"
                                           Style="{StaticResource MetricValueTextStyle}"
                                           Foreground="{StaticResource AccentBrush}" />
                            </StackPanel>
                        </Border>

                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right">
                            <Button Width="188"
                                    Margin="0,0,12,0"
                                    Content="Добавить сотрудника"
                                    Style="{StaticResource PagePrimaryButtonStyle}"
                                    Command="{Binding CreateUserCommand}"
                                    Visibility="{Binding CanManageUsers, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <Button Width="140"
                                    Content="Обновить"
                                    Style="{StaticResource PageSecondaryButtonStyle}"
                                    Command="{Binding RefreshCommand}" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Grid.Row="2"
                        Margin="0,0,0,20"
                        Padding="14,12"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushNeutral}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Загрузка сотрудников..."
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </Border>

                <Border Grid.Row="3"
                        Style="{StaticResource PagePanelBorderStyle}"
                        Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0"
                                   Background="{StaticResource PanelActiveBrush}"
                                   LastChildFill="False"
                                   Margin="0"
                                   SnapsToDevicePixels="True">
                            <Border BorderBrush="{StaticResource BorderBrushNeutral}"
                                    BorderThickness="0,0,0,1"
                                    CornerRadius="12,12,0,0"
                                    Padding="20,16"
                                    Background="Transparent">
                                <DockPanel LastChildFill="False">
                                    <StackPanel DockPanel.Dock="Left"
                                                MaxWidth="720">
                                        <TextBlock Text="Пользователи компании, роли и базовый статус аккаунтов"
                                                   Margin="0,0,0,0"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Text="Пользователи компании, роли и базовый статус аккаунтов"
                                                   Margin="0,6,0,0"
                                                   FontSize="14"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DockPanel>

                        <Grid Grid.Row="1" Margin="10,0,10,10">
                            <DataGrid ItemsSource="{Binding Users}"
                                      SelectedItem="{Binding SelectedUser, Mode=TwoWay}">
                                <DataGrid.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#16314A" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#16314A" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#DDE6F1" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#DDE6F1" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#16314A" />
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ФИО"
                                                        Binding="{Binding FullName}"
                                                        Width="2.3*" />
                                    <DataGridTextColumn Header="Логин"
                                                        Binding="{Binding Login}"
                                                        Width="1.3*" />
                                    <DataGridTemplateColumn Header="Роль"
                                                            Width="1.2*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource PillBorderStyle}"
                                                        Background="#16263A"
                                                        BorderBrush="{StaticResource AppBorderActiveBrush}">
                                                    <TextBlock Text="{Binding RoleDisplay}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource AccentBrush}" />
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Статус"
                                                            Width="1.1*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border x:Name="StatusPill"
                                                        Style="{StaticResource PillBorderStyle}"
                                                        Background="#152A1D"
                                                        BorderBrush="{StaticResource AppSuccessBrush}">
                                                    <TextBlock x:Name="StatusText"
                                                               Text="{Binding StatusDisplay}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource AppSuccessBrush}" />
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                        <Setter TargetName="StatusPill" Property="Background" Value="#3B1F24" />
                                                        <Setter TargetName="StatusPill" Property="BorderBrush" Value="{StaticResource AppErrorBrush}" />
                                                        <Setter TargetName="StatusText" Property="Foreground" Value="{StaticResource AppErrorBrush}" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Создан"
                                                        Binding="{Binding CreatedAtDisplay}"
                                                        Width="1.4*" />
                                    <DataGridTemplateColumn Header="Действия"
                                                            Width="460">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid HorizontalAlignment="Left">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <Button Grid.Column="0"
                                                            Margin="0,0,8,0"
                                                            Content="Открыть"
                                                            Style="{StaticResource TableActionButtonStyle}"
                                                            Command="{Binding DataContext.OpenEmployeeAnalyticsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}" />
                                                    <Button Grid.Column="1"
                                                            Margin="0,0,8,0"
                                                            Content="Изменить"
                                                            Style="{StaticResource TableActionButtonStyle}"
                                                            Visibility="{Binding DataContext.CanManageUsers, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                            Command="{Binding DataContext.EditUserCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}" />
                                                    <Button Grid.Column="2"
                                                            Margin="0,0,8,0"
                                                            MinWidth="138"
                                                            Content="Сбросить пароль"
                                                            Style="{StaticResource TableActionButtonStyle}"
                                                            Visibility="{Binding DataContext.CanManageUsers, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                            Command="{Binding DataContext.ResetPasswordCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}" />
                                                    <Button Grid.Column="3"
                                                            MinWidth="126"
                                                            Content="{Binding ActivationActionDisplay}"
                                                            Style="{StaticResource TableActionButtonStyle}"
                                                            Visibility="{Binding DataContext.CanManageUsers, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                            Command="{Binding DataContext.ToggleUserActivationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}" />
                                                </Grid>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border Padding="24"
                                    Background="{StaticResource AppOverlayBrush}"
                                    CornerRadius="10"
                                    Margin="20"
                                    Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Не удалось загрузить список сотрудников"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding ErrorMessage}"
                                               Margin="0,12,0,0"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource AppErrorBrush}" />
                                </StackPanel>
                            </Border>

                            <Border Padding="24"
                                    Background="{StaticResource AppOverlayBrush}"
                                    CornerRadius="10"
                                    Margin="20"
                                    Visibility="{Binding IsEmptyStateVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            MaxWidth="360">
                                    <TextBlock Text="Сотрудники не найдены"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="Когда в компании появятся сотрудники, этот список будет доступен здесь."
                                               Margin="0,12,0,0"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
