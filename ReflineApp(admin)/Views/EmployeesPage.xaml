<UserControl x:Class="Refline.Admin.Views.EmployeesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Список пользователей компании"
                           FontSize="20"
                           FontWeight="SemiBold" />
                <TextBlock Text="{}Данные загружаются из Refline.Api endpoint `/api/admin/companies/{companyId}/users`."
                           Margin="0,6,0,0"
                           Foreground="{StaticResource AppMutedTextBrush}" />
            </StackPanel>

            <Button DockPanel.Dock="Right"
                    Width="130"
                    HorizontalAlignment="Right"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Content="Обновить"
                    Command="{Binding RefreshCommand}" />
        </DockPanel>

        <Border Grid.Row="1"
                Margin="0,0,0,16"
                Padding="12"
                Background="{StaticResource AppPanelAltBrush}"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="Загрузка сотрудников..." />
        </Border>

        <StackPanel Grid.Row="2">
            <Border Padding="12"
                    Margin="0,0,0,16"
                    Background="#3F1D1D"
                    BorderBrush="{StaticResource AppErrorBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource AppErrorBrush}" />
            </Border>

            <Border Padding="18"
                    Background="{StaticResource AppPanelBrush}"
                    BorderBrush="{StaticResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                <Grid>
                    <DataGrid ItemsSource="{Binding Users}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="2*" />
                            <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="*" />
                            <DataGridTextColumn Header="Роль" Binding="{Binding RoleDisplay}" Width="*" />
                            <DataGridTextColumn Header="Статус" Binding="{Binding StatusDisplay}" Width="*" />
                            <DataGridTextColumn Header="Создан" Binding="{Binding CreatedAtDisplay}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Padding="20"
                            Background="#CC111827"
                            CornerRadius="8"
                            Visibility="{Binding HasUsers, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <TextBlock Text="Сотрудники не найдены."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource AppMutedTextBrush}" />
                    </Border>
                </Grid>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
