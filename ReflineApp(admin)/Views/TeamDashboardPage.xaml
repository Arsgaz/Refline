<UserControl x:Class="Refline.Admin.Views.TeamDashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="0,0,4,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,20">
                <StackPanel DockPanel.Dock="Left" MaxWidth="760">
                    <TextBlock Text="{Binding ScopeTitle}"
                               FontSize="28"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ScopeSubtitle}"
                               Margin="0,8,0,0"
                               Foreground="{StaticResource AppMutedTextBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </DockPanel>

            <Border Grid.Row="1"
                    Style="{StaticResource SectionCardBorderStyle}"
                    Margin="0,0,0,18">
                <WrapPanel Orientation="Horizontal" Margin="-6">
                    <StackPanel Margin="6,6,12,6">
                        <TextBlock Text="Период"
                                   Style="{StaticResource InputLabelStyle}" />
                        <StackPanel Orientation="Horizontal">
                            <Button Width="70"
                                    Height="40"
                                    Margin="0,0,8,0"
                                    Content="День"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding SetDayPeriodCommand}" />
                            <Button Width="70"
                                    Height="40"
                                    Margin="0,0,8,0"
                                    Content="Неделя"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding SetWeekPeriodCommand}" />
                            <Button Width="70"
                                    Height="40"
                                    Margin="0,0,8,0"
                                    Content="Месяц"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding SetMonthPeriodCommand}" />
                            <Button Width="110"
                                    Height="40"
                                    Content="Произвольно"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding SetCustomPeriodCommand}" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Margin="6,6,12,6" Visibility="{Binding IsReferenceDateVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Опорная дата"
                                   Style="{StaticResource InputLabelStyle}" />
                        <DatePicker SelectedDate="{Binding ReferenceDate, Mode=TwoWay}"
                                    Width="130"
                                    Height="40" 
                                    VerticalContentAlignment="Center" />
                    </StackPanel>

                    <StackPanel Margin="6,6,12,6" Visibility="{Binding IsCustomDatesVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="С"
                                   Style="{StaticResource InputLabelStyle}" />
                        <DatePicker SelectedDate="{Binding CustomStartDate, Mode=TwoWay}"
                                    Width="130"
                                    Height="40" 
                                    VerticalContentAlignment="Center" />
                    </StackPanel>

                    <StackPanel Margin="6,6,12,6" Visibility="{Binding IsCustomDatesVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="По"
                                   Style="{StaticResource InputLabelStyle}" />
                        <DatePicker SelectedDate="{Binding CustomEndDate, Mode=TwoWay}"
                                    Width="130"
                                    Height="40" 
                                    VerticalContentAlignment="Center" />
                    </StackPanel>

                    <StackPanel Margin="6,6,12,6" Visibility="{Binding IsReferenceDateVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Диапазон"
                                   Style="{StaticResource InputLabelStyle}" />
                        <Border Style="{StaticResource CardBorderStyle}"
                                Background="{StaticResource AppPanelElevatedBrush}"
                                Padding="14,10"
                                MinHeight="40">
                            <TextBlock Text="{Binding PeriodLabel}" VerticalAlignment="Center" />
                        </Border>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="6,6,12,6">
                        <Button Width="40"
                                Height="40"
                                Margin="0,0,8,0"
                                Content="←"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding PreviousPeriodCommand}" />
                        <Button Width="40"
                                Height="40"
                                Margin="0,0,8,0"
                                Content="→"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding NextPeriodCommand}" />
                        <Button Width="90"
                                Height="40"
                                Content="Сегодня"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding TodayCommand}" />
                    </StackPanel>

                    <Button Width="130"
                            Height="40"
                            VerticalAlignment="Bottom"
                            Margin="6,6,6,6"
                            Content="Обновить"
                            Command="{Binding LoadCommand}" />
                </WrapPanel>
            </Border>

            <Grid Grid.Row="2" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,14,14">
                        <StackPanel>
                            <TextBlock Text="Сотрудников в выборке" Foreground="{StaticResource AppMutedTextBrush}" />
                            <TextBlock Text="{Binding EmployeesCountDisplay}" Margin="0,12,0,0" FontSize="28" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="Среднее продуктивное время" Foreground="{StaticResource AppMutedTextBrush}" />
                            <TextBlock Text="{Binding AverageProductiveDisplay}" Margin="0,12,0,0" FontSize="28" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,14,14">
                        <StackPanel>
                            <TextBlock Text="Общее отслеженное время" Foreground="{StaticResource AppMutedTextBrush}" />
                            <TextBlock Text="{Binding TotalTrackedDisplay}" Margin="0,12,0,0" FontSize="28" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="Общее время бездействия" Foreground="{StaticResource AppMutedTextBrush}" />
                            <TextBlock Text="{Binding TotalIdleDisplay}" Margin="0,12,0,0" FontSize="28" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Общее продуктивное время" Foreground="{StaticResource AppMutedTextBrush}" />
                            <TextBlock Text="{Binding TotalProductiveDisplay}" Margin="0,12,0,0" FontSize="28" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Топ сотрудник" Foreground="{StaticResource AppMutedTextBrush}" />
                            <TextBlock Text="{Binding TopEmployeeName}" Margin="0,12,0,0" FontSize="22" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding TopEmployeeMetric}" Margin="0,8,0,0" Foreground="{StaticResource AppMutedTextBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <Border Grid.Row="3"
                    Margin="0,0,0,18"
                    Padding="12,10"
                    Background="{StaticResource AppPanelElevatedBrush}"
                    BorderBrush="{StaticResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="Загрузка сводной аналитики..."
                           Foreground="{StaticResource AppMutedTextBrush}" />
            </Border>

            <Border Grid.Row="4"
                    Margin="0,0,0,18"
                    Padding="16,14"
                    Background="#3D1C22"
                    BorderBrush="{StaticResource AppErrorBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Не удалось загрузить сводную аналитику"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ErrorMessage}"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               Foreground="#FFD1D1" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="5">
                <Border Style="{StaticResource SectionCardBorderStyle}"
                        Visibility="{Binding IsEmptyStateVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="420">
                        <TextBlock Text="За выбранный период данных недостаточно"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center" />
                        <TextBlock Text="Попробуйте выбрать другой период. Экран корректно обрабатывает ситуации, когда активности мало или нет совсем."
                                   Margin="0,12,0,0"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource AppMutedTextBrush}" />
                    </StackPanel>
                </Border>

                <Grid Visibility="{Binding HasAnyData, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Style="{StaticResource SectionCardBorderStyle}"
                            Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="Динамика по дням"
                                       FontSize="20"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Суммарное отслеженное время по доступной команде или компании."
                                       Margin="0,8,0,18"
                                       Foreground="{StaticResource AppMutedTextBrush}" />

                            <ItemsControl ItemsSource="{Binding DailyBuckets}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="6,0,6,0"
                                              VerticalAlignment="Bottom">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="130" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0"
                                                       Text="{Binding TotalDisplay}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,0,0,10"
                                                       FontSize="12"
                                                       Foreground="{StaticResource AppMutedTextBrush}" />
                                            <Border Grid.Row="1"
                                                    Width="34"
                                                    Height="{Binding BarHeight}"
                                                    VerticalAlignment="Bottom"
                                                    HorizontalAlignment="Center"
                                                    Background="{StaticResource AppAccentBrush}"
                                                    CornerRadius="8,8,0,0" />
                                            <TextBlock Grid.Row="2"
                                                       Text="{Binding Label}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,10,0,0"
                                                       FontSize="12"
                                                       Foreground="{StaticResource AppMutedTextBrush}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource SectionCardBorderStyle}"
                                Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="Топ сотрудников"
                                           FontSize="20"
                                           FontWeight="SemiBold" />
                                <ItemsControl ItemsSource="{Binding TopEmployees}" Margin="0,18,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10"
                                                    Padding="12"
                                                    Background="{StaticResource AppPanelElevatedBrush}"
                                                    BorderBrush="{StaticResource AppBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding FullName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding Role}" Margin="0,6,0,0" Foreground="{StaticResource AppMutedTextBrush}" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Margin="18,0,0,0">
                                                        <TextBlock Text="{Binding ProductiveDisplay}" HorizontalAlignment="Right" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding TotalDisplay}" Margin="0,6,0,0" Foreground="{StaticResource AppMutedTextBrush}" HorizontalAlignment="Right" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Style="{StaticResource SectionCardBorderStyle}"
                                Margin="12,0,12,0">
                            <StackPanel>
                                <TextBlock Text="Топ приложений"
                                           FontSize="20"
                                           FontWeight="SemiBold" />
                                <ItemsControl ItemsSource="{Binding Applications}" Margin="0,18,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10"
                                                    Padding="12"
                                                    Background="{StaticResource AppPanelElevatedBrush}"
                                                    BorderBrush="{StaticResource AppBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                <DockPanel>
                                                    <TextBlock Text="{Binding DurationDisplay}" DockPanel.Dock="Right" Foreground="{StaticResource AppMutedTextBrush}" />
                                                    <TextBlock Text="{Binding Name}" TextWrapping="Wrap" FontWeight="SemiBold" />
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Style="{StaticResource SectionCardBorderStyle}"
                                Margin="12,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Категории"
                                           FontSize="20"
                                           FontWeight="SemiBold" />
                                <ItemsControl ItemsSource="{Binding Categories}" Margin="0,18,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10"
                                                    Padding="12"
                                                    Background="{StaticResource AppPanelElevatedBrush}"
                                                    BorderBrush="{StaticResource AppBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                <DockPanel>
                                                    <TextBlock Text="{Binding DurationDisplay}" DockPanel.Dock="Right" Foreground="{StaticResource AppMutedTextBrush}" />
                                                    <TextBlock Text="{Binding Name}" TextWrapping="Wrap" FontWeight="SemiBold" />
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
