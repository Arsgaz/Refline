<Window x:Class="Refline.Admin.Views.UserEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пользователь"
        Width="520"
        Height="560"
        ResizeMode="NoResize"
        Background="{StaticResource AppBackgroundBrush}"
        WindowStartupLocation="CenterOwner">
    <Border Margin="18"
            Padding="22"
            Background="{StaticResource AppPanelBrush}"
            BorderBrush="{StaticResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock x:Name="DialogTitleText"
                           FontSize="22"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="DialogSubtitleText"
                           Margin="0,8,0,0"
                           Foreground="{StaticResource AppMutedTextBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <ScrollViewer Grid.Row="1"
                          Margin="0,22,0,22"
                          VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="ФИО"
                               Style="{StaticResource InputLabelStyle}" />
                    <TextBox Grid.Row="1"
                             x:Name="FullNameTextBox"
                             MaxLength="200"
                             MinHeight="44" />

                    <TextBlock Grid.Row="2"
                               Text="Логин"
                               Margin="0,18,0,6"
                               Style="{StaticResource InputLabelStyle}" />
                    <TextBox Grid.Row="3"
                             x:Name="LoginTextBox"
                             MaxLength="100"
                             MinHeight="44" />

                    <Grid Grid.Row="4"
                          Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Роль"
                                       Margin="0,0,0,6"
                                       Style="{StaticResource InputLabelStyle}" />
                            <ComboBox x:Name="RoleComboBox"
                                      MinHeight="44"
                                      DisplayMemberPath="Text"
                                      SelectedValuePath="Value" />
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    x:Name="ManagerPanel">
                            <TextBlock Text="Менеджер"
                                       Margin="0,0,0,6"
                                       Style="{StaticResource InputLabelStyle}" />
                            <ComboBox x:Name="ManagerComboBox"
                                      MinHeight="44"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Id" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </ScrollViewer>

            <DockPanel Grid.Row="2">
                <TextBlock x:Name="ValidationMessageText"
                           DockPanel.Dock="Left"
                           Margin="0,0,16,0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource AppErrorBrush}"
                           TextWrapping="Wrap" />
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Width="110"
                            x:Name="CancelButton"
                            Height="42"
                            Margin="0,0,12,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="Отмена"
                            IsCancel="True"
                            Click="CancelButton_Click" />
                    <Button Width="140"
                            x:Name="SaveButton"
                            Height="42"
                            Content="Сохранить"
                            IsDefault="True"
                            Click="SaveButton_Click" />
                </StackPanel>
            </DockPanel>
        </Grid>
    </Border>
</Window>
