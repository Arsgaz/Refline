<Window x:Class="Refline.Admin.Views.UserEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:Refline.Admin.Models"
        Title="Пользователь"
        Width="520"
        Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Border Margin="18"
            Padding="22"
            Background="{StaticResource AppPanelBrush}"
            BorderBrush="{StaticResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock x:Name="DialogTitleText"
                           FontSize="22"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="DialogSubtitleText"
                           Margin="0,8,0,0"
                           Foreground="{StaticResource AppMutedTextBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Row="1"
                        Margin="0,22,0,22">
                <TextBlock Text="ФИО"
                           Style="{StaticResource InputLabelStyle}" />
                <TextBox x:Name="FullNameTextBox"
                         MaxLength="200" />

                <TextBlock Text="Логин"
                           Margin="0,18,0,6"
                           Style="{StaticResource InputLabelStyle}" />
                <TextBox x:Name="LoginTextBox"
                         MaxLength="100" />

                <StackPanel x:Name="PasswordPanel"
                            Margin="0,18,0,0">
                    <TextBlock Text="Пароль"
                               Style="{StaticResource InputLabelStyle}" />
                    <PasswordBox x:Name="PasswordTextBox"
                                 MaxLength="100" />
                </StackPanel>

                <TextBlock Text="Роль"
                           Margin="0,18,0,6"
                           Style="{StaticResource InputLabelStyle}" />
                <ComboBox x:Name="RoleComboBox"
                          Height="44"
                          MinWidth="220"
                          SelectedIndex="2"
                          SelectedValuePath="Tag">
                    <ComboBoxItem Tag="{x:Static models:UserRole.Admin}"
                                  Content="Администратор" />
                    <ComboBoxItem Tag="{x:Static models:UserRole.Manager}"
                                  Content="Менеджер" />
                    <ComboBoxItem Tag="{x:Static models:UserRole.Employee}"
                                  Content="Сотрудник" />
                </ComboBox>

                <TextBlock Text="Менеджер"
                           Margin="0,18,0,6"
                           Style="{StaticResource InputLabelStyle}" />
                <ComboBox x:Name="ManagerComboBox"
                          Height="44"
                          MinWidth="220"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Id" />
            </StackPanel>

            <DockPanel Grid.Row="2">
                <TextBlock x:Name="ValidationMessageText"
                           DockPanel.Dock="Left"
                           Margin="0,0,16,0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource AppErrorBrush}"
                           TextWrapping="Wrap" />
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Width="110"
                            x:Name="CancelButton"
                            Height="42"
                            Margin="0,0,12,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="Отмена"
                            IsCancel="True"
                            Click="CancelButton_Click" />
                    <Button Width="140"
                            x:Name="SaveButton"
                            Height="42"
                            Content="Сохранить"
                            IsDefault="True"
                            Click="SaveButton_Click" />
                </StackPanel>
            </DockPanel>
        </Grid>
    </Border>
</Window>
