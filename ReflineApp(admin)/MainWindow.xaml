<Window x:Class="Refline.Admin.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:Refline.Admin.ViewModels"
        xmlns:views="clr-namespace:Refline.Admin.Views"
        Title="Refline Admin"
        Width="1280"
        Height="780"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:EmployeesViewModel}">
            <views:EmployeesPage />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:EmployeeAnalyticsViewModel}">
            <views:EmployeeAnalyticsPage />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:TeamDashboardViewModel}">
            <views:TeamDashboardPage />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:ActivityClassificationRulesViewModel}">
            <views:ActivityClassificationRulesPage />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:LicensesViewModel}">
            <views:LicensesPage />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:PlaceholderViewModel}">
            <views:PlaceholderPage />
        </DataTemplate>

        <Style x:Key="AdminSidebarNavButton" TargetType="Button">
            <Setter Property="Width" Value="180" />
            <Setter Property="Height" Value="46" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#162033" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#2DC7FF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#11263A" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#2DC7FF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AdminSidebarPrimaryButton" TargetType="Button" BasedOn="{StaticResource AdminSidebarNavButton}">
            <Setter Property="Background" Value="#11263A" />
            <Setter Property="BorderBrush" Value="#2DC7FF" />
            <Setter Property="Foreground" Value="#2DC7FF" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="0"
                Background="#111827"
                BorderBrush="#1E2A3D"
                BorderThickness="0,0,1,0">
            <Grid Margin="18,28,18,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Margin="0,8,0,28"
                            HorizontalAlignment="Center">
                    <TextBlock Text="Refline"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="{StaticResource AppAccentBrush}" />
                    <TextBlock Text="Admin Console"
                               Margin="0,4,0,0"
                               FontSize="24"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Управление компанией"
                               Margin="0,8,0,0"
                               Foreground="#94A3B8"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Row="1"
                            HorizontalAlignment="Center">
                    <Button Style="{StaticResource AdminSidebarNavButton}"
                            Command="{Binding ShowEmployeesCommand}">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="&#xE716;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="17"
                                       Margin="0,0,8,0"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            <TextBlock Text="Сотрудники"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource AdminSidebarNavButton}"
                            Command="{Binding ShowAnalyticsCommand}">
                        <Button.Visibility>
                            <Binding Path="CanViewAnalyticsSection" Converter="{StaticResource BooleanToVisibilityConverter}" />
                        </Button.Visibility>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="&#xE9D2;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="17"
                                       Margin="0,0,8,0"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            <TextBlock Text="Аналитика"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource AdminSidebarNavButton}"
                            Command="{Binding ShowLicensesCommand}">
                        <Button.Visibility>
                            <Binding Path="CanViewLicensesSection" Converter="{StaticResource BooleanToVisibilityConverter}" />
                        </Button.Visibility>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="&#xE192;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="17"
                                       Margin="0,0,8,0"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            <TextBlock Text="Лицензии"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource AdminSidebarNavButton}"
                            Command="{Binding ShowRulesCommand}">
                        <Button.Visibility>
                            <Binding Path="CanViewRulesSection" Converter="{StaticResource BooleanToVisibilityConverter}" />
                        </Button.Visibility>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="&#xE713;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="17"
                                       Margin="0,0,8,0"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            <TextBlock Text="Правила"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="2"
                            HorizontalAlignment="Center">
                    <Border Style="{StaticResource CardBorderStyle}"
                            Background="#162033"
                            BorderBrush="#1E2A3D"
                            Padding="14"
                            Width="180">
                        <StackPanel>
                            <TextBlock Text="{Binding CurrentUserDisplayName}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center" />
                            <TextBlock Text="{Binding CurrentUserRoleDisplay}"
                                       Margin="0,6,0,0"
                                       Foreground="#94A3B8"
                                       TextAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Button Content="Выход"
                            Margin="0,14,0,0"
                            Width="180"
                            Style="{StaticResource AdminSidebarPrimaryButton}"
                            Command="{Binding ExitCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="26">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding CurrentSectionTitle}"
                               FontSize="32"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding CurrentSectionSubtitle}"
                               Margin="0,8,0,0"
                               Foreground="{StaticResource AppMutedTextBrush}" />
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="14,10"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="{StaticResource AppPanelBrush}"
                        BorderBrush="{StaticResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Система"
                                   FontSize="12"
                                   Foreground="{StaticResource AppMutedTextBrush}" />
                        <TextBlock Text="Refline Admin"
                                   Margin="0,4,0,0"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>

            <ContentControl Grid.Row="1"
                            Content="{Binding CurrentPageViewModel}" />
        </Grid>
    </Grid>
</Window>
